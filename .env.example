# ─────────────────────────────────────────────────────────
# Environment Variables — Alfursan Auto
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────
# Injected automatically by the Supabase Vercel connector.
# Add manually if not using the connector.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# ── Resend (email notifications) ─────────────────────────
# Server-only
RESEND_API_KEY=
# The verified sender address (must match a domain verified in Resend)
RESEND_FROM_ADDRESS=noreply@alfursanauto.ca
# Dealer inbox that receives "new application" notifications
RESEND_DEALER_EMAIL=

# ── Upstash Redis (rate limiting) ────────────────────────
# Server-only
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
