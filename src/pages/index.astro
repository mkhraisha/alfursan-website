---
import Layout from "../layouts/Layout.astro";
import PopularMakes from "../components/PopularMakes";
import { formatPrice, getCars } from "../lib/wordpress";

const cars = await getCars(100);
const featuredCars = cars.slice(0, 5);
const makeCounts = cars.reduce<Record<string, number>>((acc, car) => {
  if (!car.make) {
    return acc;
  }

  acc[car.make] = (acc[car.make] ?? 0) + 1;
  return acc;
}, {});

const carsByMake = cars.reduce<Record<string, typeof cars>>((acc, car) => {
  if (!car.make) return acc;
  if (!acc[car.make]) acc[car.make] = [];
  acc[car.make].push(car);
  return acc;
}, {});

const PREFERRED_MAKES = ["Hyundai", "Honda", "Mazda", "Tesla", "Toyota"];

const popularMakesData = Object.entries(makeCounts)
  .sort((a, b) => {
    const ai = PREFERRED_MAKES.findIndex(m => m.toLowerCase() === a[0].toLowerCase());
    const bi = PREFERRED_MAKES.findIndex(m => m.toLowerCase() === b[0].toLowerCase());
    if (ai !== -1 && bi !== -1) return ai - bi;
    if (ai !== -1) return -1;
    if (bi !== -1) return 1;
    return b[1] - a[1];
  })
  .slice(0, 5)
  .map(([make, count]) => ({
    make,
    count,
    cars: carsByMake[make] ?? [],
  }));

const popularMakes = Object.entries(makeCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 5);

const allMakes = Object.keys(makeCounts).sort();
const totalListings = cars.length;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "AutoDealer",
  name: "Alfursan Auto",
  url: "https://alfursanauto.ca",
  logo: "https://alfursanauto.ca/wp-content/uploads/2025/06/al-fursan-logo-transparent.png",
  image:
    "https://alfursanauto.ca/wp-content/uploads/2026/02/alfursan-auto-website-background.png",
  description:
    "Trusted used car dealership in the Greater Toronto Area specializing in retail sales, wholesale deals, and international vehicle exports.",
  telephone: "+1-416-838-4007",
  email: "sales@alfursanauto.ca",
  address: {
    "@type": "PostalAddress",
    streetAddress: "5866 Mayfield Rd",
    addressLocality: "Caledon",
    addressRegion: "ON",
    postalCode: "L7C 0Z6",
    addressCountry: "CA",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 43.7761,
    longitude: -79.8683,
  },
  sameAs: [
    "https://www.facebook.com/people/Alfursan-Auto-Exports/61576687765706/",
    "https://www.instagram.com/alfursanauto/",
  ],
};
---

<Layout
  title="Alfursan Auto | Used Cars In GTA"
  description="Good cars. Fair prices. Nothing hidden. Browse inspected used vehicles at Alfursan Auto."
  schema={localBusinessSchema}
  transparentHeader
>
  <section class="hero">
    <div class="hero-content">
      <div class="hero-left">
        <img
          src="https://alfursanauto.ca/wp-content/uploads/2025/10/UCDA-Member-Logo-scaled-1-1536x907.gif"
          alt="UCDA Member"
          class="ucda-badge"
        />
        <h1>Good cars.<br />Fair prices.<br />Nothing hidden.</h1>
        <p class="hero-subtitle">
          Looking for something specific? We'll find it, certify it, and get you
          the best deal.
        </p>
        <a href="/search/" class="btn btn-outline-hero">View Cars</a>
      </div>

      <div class="hero-right">
        <div class="hero-search-panel">
          <form action="/search/" method="get" class="hero-search-form">
            <select name="make" class="hero-field">
              <option value="">All Makes</option>
              {
                allMakes.map((make) => (
                  <option value={make}>
                    {make} ({makeCounts[make]})
                  </option>
                ))
              }
            </select>
            <div class="hero-price-row">
              <select name="min_price" class="hero-field">
                <option value="">Min Price</option>
              </select>
              <select name="max_price" class="hero-field">
                <option value="">Max Price</option>
              </select>
            </div>
            <div class="hero-search-actions">
              <a href="/search/" class="hero-advanced">Advanced Search</a>
              <button type="submit" class="btn btn-primary hero-search-btn"
                >Search</button
              >
            </div>
          </form>
          <p class="hero-search-label">
            We found <strong>{totalListings}</strong> listings for you.
          </p>
        </div>
      </div>
    </div>

    <img
      src="https://alfursanauto.ca/wp-content/uploads/2025/06/full-body-alfursan-auto.png"
      alt=""
      class="hero-mascot"
      aria-hidden="true"
      loading="eager"
    />
  </section>

  <main class="container">
    <section class="featured">
      <div class="section-head">
        <p class="section-eyebrow">Hand picked</p>
        <h2>Featured Listings</h2>
      </div>

      <div class="featured-grid">
        {
          featuredCars[0] && (
            <article class="card card-hero">
              <a
                href={`/listing/${featuredCars[0].slug}/`}
                class="card-img-link"
              >
                {featuredCars[0].image ? (
                  <img
                    src={featuredCars[0].image}
                    alt={featuredCars[0].title}
                    loading="lazy"
                  />
                ) : (
                  <div class="placeholder">No image</div>
                )}
                {featuredCars[0].offerType?.toLowerCase() === "sold" && (
                  <span class="sold-badge">Sold</span>
                )}
                {featuredCars[0].images.length > 0 && (
                  <span class="img-count">{featuredCars[0].images.length}</span>
                )}
              </a>
              <div class="card-body">
                <a
                  href={`/listing/${featuredCars[0].slug}/`}
                  class="card-title-link"
                >
                  <h3>{featuredCars[0].title}</h3>
                </a>
                <div class="card-specs-row">
                  <div class="card-specs">
                    {featuredCars[0].year && <span>{featuredCars[0].year}</span>}
                    {featuredCars[0].mileageKm && (
                      <span>{Number(featuredCars[0].mileageKm).toLocaleString("en-CA")}KM</span>
                    )}
                    {featuredCars[0].transmission && (
                      <span>{featuredCars[0].transmission}</span>
                    )}
                    {featuredCars[0].fuelType && (
                      <span>{featuredCars[0].fuelType}</span>
                    )}
                    {featuredCars[0].driveType && (
                      <span>{featuredCars[0].driveType}</span>
                    )}
                  </div>
                  <p class="price">{formatPrice(featuredCars[0].price)}</p>
                </div>
              </div>
            </article>
          )
        }

        <div class="featured-side">
          {
            featuredCars.slice(1, 5).map((car) => (
              <article class="card card-sm">
                <a href={`/listing/${car.slug}/`} class="card-img-link">
                  {car.image ? (
                    <img src={car.image} alt={car.title} loading="lazy" />
                  ) : (
                    <div class="placeholder">No image</div>
                  )}
                  {car.offerType?.toLowerCase() === "sold" && (
                    <span class="sold-badge">Sold</span>
                  )}
                  {car.images.length > 0 && (
                    <span class="img-count">{car.images.length}</span>
                  )}
                </a>
                <div class="card-body">
                  <a href={`/listing/${car.slug}/`} class="card-title-link">
                    <h3>{car.title}</h3>
                  </a>
                  <p class="price">{formatPrice(car.price)}</p>
                  <div class="card-specs">
                    {car.year && <span>{car.year}</span>}
                    {car.mileageKm && <span>{Number(car.mileageKm).toLocaleString("en-CA")}KM</span>}
                    {car.transmission && <span>{car.transmission}</span>}
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <div class="social-bar">
      <div class="social-bar-follow">
        <span class="social-bar-label">Follow us</span>
        <div class="social-bar-icons">
          <a href="https://www.facebook.com/people/Alfursan-Auto-Exports/61576687765706/" target="_blank" rel="noreferrer" aria-label="Facebook" class="social-bar-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512" width="14" height="14"><path d="M80 299.3V512H196V299.3h86.5l18-97.8H196V166.9c0-51.7 20.3-71.5 72.7-71.5c16.3 0 29.4 .4 37 1.2V7.9C291.4 4 256.4 0 236.2 0C129.3 0 80 50.5 80 159.4v42.1H14v97.8H80z" fill="currentColor"/></svg>
          </a>
          <a href="#" target="_blank" rel="noreferrer" aria-label="X / Twitter" class="social-bar-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="14" height="14"><path d="M389.2 48h70.6L305.6 224.2 487 464H345L233.7 318.6 106.5 464H35.8L200.7 275.5 26.8 48H172.4L272.9 180.9 389.2 48zM364.4 421.8h39.1L151.1 88h-42L364.4 421.8z" fill="currentColor"/></svg>
          </a>
          <a href="https://www.instagram.com/alfursanauto/" target="_blank" rel="noreferrer" aria-label="Instagram" class="social-bar-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" width="14" height="14"><path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z" fill="currentColor"/></svg>
          </a>
        </div>
      </div>
      <a href="/search/" class="btn btn-primary social-bar-cta">View {totalListings} Used</a>
    </div>

    <PopularMakes makes={popularMakesData} client:load />

    <section class="why-us">
      <h2>Why choose us?</h2>
      <div class="why-grid">
        <article>
          <img
            src="https://alfursanauto.ca/wp-content/uploads/2025/06/alfursan-auto-transparent-deals.png"
            alt="Honest Deals"
            class="why-icon"
          />
          <h3>Honest Deals, No Surprises</h3>
          <p>
            We believe in transparent pricing and straightforward service. No
            hidden fees, no pressure. Just real value.
          </p>
        </article>
        <article>
          <img
            src="https://alfursanauto.ca/wp-content/uploads/2025/06/alfursan-auto-inspected.png"
            alt="Inspected Inventory"
            class="why-icon"
          />
          <h3>Carefully Inspected Inventory</h3>
          <p>
            Every vehicle is thoroughly checked for quality, safety, and
            performance. We make sure you drive away with confidence.
          </p>
        </article>
        <article>
          <img
            src="https://alfursanauto.ca/wp-content/uploads/2025/06/alfursan-auto-location.png"
            alt="Local & Global"
            class="why-icon"
          />
          <h3>Local & Global Service</h3>
          <p>
            Whether you're buying in the GTA or exporting internationally, we
            manage the details so you don't have to.
          </p>
        </article>
      </div>
    </section>
  </main>
</Layout>

<style>
  .container {
    max-width: 1466px;
    margin: 0 auto;
    padding: 1.4rem 30px 4.5rem;
  }

  .hero {
    background: var(--dark)
      url("https://alfursanauto.ca/wp-content/uploads/2026/02/alfursan-auto-website-background.png")
      center / cover;
    color: #fff;
    padding: 7rem 2.5rem 7.5rem;
    position: relative;
    overflow: hidden;
  }

  .hero-content {
    max-width: 1466px;
    margin: 0 auto;
    padding: 0 30px;
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: start;
    gap: 2rem;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-subtitle {
    max-width: 48ch;
    color: var(--subtitle-on-dark);
    font-size: clamp(0.875rem, 1.2vw, 16px);
    font-weight: 700;
    line-height: 1.55;
  }

  .btn-outline-hero {
    display: inline-block;
    text-decoration: none;
    border: 1px solid var(--brand-red);
    color: #fff;
    background: transparent;
    padding: 18px 40px;
    font-weight: 700;
    font-size: 17px;
    border-radius: 6px;
    margin-top: 0.5rem;
    transition:
      background 0.2s,
      color 0.2s;
  }

  .btn-outline-hero:hover {
    background: var(--brand-red);
    color: #fff;
  }

  h1 {
    margin: 0 0 0.5rem;
    line-height: 1.0;
    font-family: "Bebas Neue", cursive;
    font-size: clamp(2.8rem, 5.5vw, 87px);
    font-weight: 400;
    letter-spacing: 0.1px;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.45);
  }

  h2 {
    margin: 0;
  }

  .ucda-badge {
    width: 180px;
    height: auto;
    margin-bottom: 1rem;
    border-radius: 8px;
    object-fit: contain;
  }

  /* Hero search panel (right side white card) */
  .hero-search-panel {
    background: rgba(255, 255, 255, 0.95);
    border-radius: 10px;
    padding: 1.2rem 1.4rem;
    min-width: 320px;
    max-width: 380px;
    color: var(--ink);
  }

  .hero-search-form {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .hero-field {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 0.6rem 0.75rem;
    font-size: 0.9rem;
    background: #fff;
    color: var(--ink);
    font-weight: 600;
    appearance: auto;
  }

  .hero-price-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }

  .hero-search-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .hero-advanced {
    color: var(--muted);
    font-size: 0.85rem;
    text-decoration: none;
    font-weight: 600;
  }

  .hero-advanced:hover {
    color: var(--ink);
  }

  .hero-search-btn {
    padding: 0.55rem 1.8rem;
    font-size: 0.88rem;
  }

  .hero-search-label {
    margin: 0.55rem 0 0;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .hero-search-label strong {
    color: var(--ink);
  }

  .btn {
    display: inline-block;
    text-decoration: none;
    border-radius: 10px;
    padding: 18px 40px;
    font-weight: 700;
    font-size: 16px;
  }

  .btn-primary {
    color: #fff;
    background: var(--brand-red);
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 0.9rem;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .section-eyebrow {
    width: 100%;
    margin: 0;
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--brand-red);
    font-style: italic;
    letter-spacing: 0.02em;
  }

  .section-head h2 {
    font-weight: 900;
    font-size: clamp(2rem, 4vw, 50px);
  }

  .section-head a {
    color: var(--brand-red);
    text-decoration: none;
    font-weight: 700;
  }

  /* ── Featured grid ── */
  .featured {
    margin-bottom: 1.5rem;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .featured-side {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  /* ── Cards ── */
  .card {
    background: var(--surface);
    border: none;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: none;
    transition: box-shadow 0.2s;
    display: flex;
    flex-direction: column;
  }

  /* Side cards use dark theme matching live site */
  .card-sm {
    background: #222732;
  }

  .card:hover {
    box-shadow: 0 14px 32px rgba(16, 24, 40, 0.1);
  }

  .card-hero {
    background: #222732;
  }

  .card-hero .card-img-link {
    flex: 1;
    min-height: 0;
  }

  .card-hero .card-img-link img,
  .card-hero .card-img-link .placeholder {
    height: 100%;
    object-fit: cover;
  }

  .card-sm .card-img-link img,
  .card-sm .card-img-link .placeholder {
    height: 182px;
    object-fit: cover;
  }

  .card-img-link {
    display: block;
    position: relative;
  }

  .sold-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    background: var(--brand-red);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.2rem 0.55rem;
    border-radius: 6px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .img-count {
    position: absolute;
    bottom: 10px;
    right: 10px;
    background: rgba(0, 0, 0, 0.6);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.15rem 0.45rem;
    border-radius: 5px;
  }

  img,
  .placeholder {
    display: block;
    width: 100%;
    object-fit: cover;
    background: var(--bg-placeholder);
  }

  .placeholder {
    display: grid;
    place-items: center;
    color: var(--placeholder);
    font-size: 0.9rem;
  }

  .card-body {
    padding: 0.95rem;
  }

  .card-title-link {
    text-decoration: none;
    color: var(--ink);
  }

  /* Higher specificity to beat .card-body a { color: var(--brand-red) } */
  .card-sm .card-title-link {
    color: #fff;
  }

  h3 {
    margin: 0 0 0.35rem;
    font-size: 17px;
    line-height: 1.3;
  }

  .card-sm h3 {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .meta {
    color: var(--muted);
    font-size: 0.92rem;
    margin: 0 0 0.4rem;
  }

  .price {
    margin: 0 0 0.5rem;
    font-weight: 800;
    font-size: 20px;
    color: var(--ink);
  }

  .card-sm .price {
    color: #fff;
  }

  .card-specs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .card-sm .card-specs {
    flex-wrap: nowrap;
    overflow: hidden;
  }

  .card-specs span {
    font-size: 0.75rem;
    color: var(--muted);
    background: transparent;
    border-radius: 4px;
    padding: 2px 4px;
    white-space: nowrap;
  }

  /* On dark card backgrounds, muted text needs to be lighter */
  .card-sm .card-specs span:not(:first-child) {
    color: #99a1b2;
  }

  /* Year chip: red pill for side cards */
  .card-sm .card-specs span:first-child {
    background: var(--brand-red);
    color: #fff;
    padding: 2px 8px;
  }

  .card-body a {
    color: var(--brand-red);
    font-weight: 700;
    text-decoration: none;
  }

  .why-us {
    margin-top: 2.5rem;
    padding: 3rem 0;
  }

  .why-us h2 {
    font-size: clamp(2rem, 4vw, 50px);
    font-weight: 900;
    line-height: 66px;
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .why-grid article {
    background: transparent;
    border: none;
    border-radius: 0;
    padding: 2rem 1.5rem;
    text-align: center;
    box-shadow: none;
  }

  .why-icon {
    width: 140px;
    height: 140px;
    object-fit: contain;
    background: transparent;
    margin: 0 auto 1.5rem;
  }

  .why-grid h3 {
    margin: 0 0 0.5rem;
    font-size: 24px;
    font-weight: 700;
    line-height: 40px;
  }

  .why-grid p {
    margin: 0;
    color: var(--muted-dark);
    font-size: 16px;
    line-height: 27px;
  }

  /* ── Hero mascot ── */
  .hero-mascot {
    display: none;
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-30%);
    height: 95%;
    width: auto;
    max-width: 420px;
    object-fit: contain;
    pointer-events: none;
    z-index: 0;
    background: transparent;
  }

  @media (min-width: 1024px) {
    .hero-mascot {
      display: block;
    }
  }

  /* ── Card hero overlay ── */
  .card-hero {
    position: relative;
  }

  .card-hero .card-img-link {
    flex: 1;
    min-height: 280px;
  }

  .card-hero .card-img-link img,
  .card-hero .card-img-link .placeholder {
    height: 100%;
    min-height: 280px;
  }

  .card-hero .card-body {
    position: absolute;
    bottom: 0;
    left: 0;
