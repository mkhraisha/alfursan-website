---
import LoanCalculator from "../../components/LoanCalculator";
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Loan Calculator | Alfursan Auto"
  description="Estimate your monthly car loan payments with our free calculator. Adjust price, interest rate, term, and down payment."
>
  <main class="container">
    <section class="heading">
      <p class="kicker">Tools</p>
      <h1>Loan Calculator</h1>
    </section>

    <LoanCalculator client:load />
  </main>
</Layout>

<style>
  .container {
    max-width: 860px;
    margin: 0 auto;
    padding: 2rem 30px 4rem;
  }

  .heading {
    background: var(--dark);
    color: #fff;
    border-radius: 16px;
    padding: 1.2rem;
    margin-bottom: 1.5rem;
  }

  .kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8rem;
    color: var(--subtitle-on-dark);
    font-weight: 800;
  }

  h1 {
    margin: 0.35rem 0 0;
    font-size: clamp(1.45rem, 3.3vw, 2.2rem);
  }

  :global(.calc-wrapper) {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 1.5rem;
    box-shadow: 0 10px 24px rgba(16, 24, 40, 0.05);
  }

  :global(.calc-intro h2) {
    margin: 0 0 0.5rem;
    font-size: 1.35rem;
  }

  :global(.calc-intro p) {
    margin: 0 0 1.2rem;
    color: var(--muted-dark);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  :global(.calc-fields) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 560px) {
    :global(.calc-fields) {
      grid-template-columns: 1fr;
    }
  }

  :global(.calc-fields label) {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--filter-label);
  }

  :global(.required) {
    color: var(--brand-red);
  }

  :global(.calc-fields input) {
    border: 1px solid var(--input-border);
    border-radius: 8px;
    padding: 0.55rem 0.65rem;
    font-size: 0.95rem;
    background: #fff;
    width: 100%;
  }

  :global(.input-with-suffix) {
    display: flex;
    align-items: center;
    border: 1px solid var(--input-border);
    border-radius: 8px;
    background: #fff;
    overflow: hidden;
  }

  :global(.input-with-suffix input) {
    border: none;
    border-radius: 0;
    flex: 1;
  }

  :global(.suffix),
  :global(.prefix) {
    padding: 0 0.6rem;
    color: var(--muted);
    font-weight: 700;
    font-size: 0.9rem;
    flex-shrink: 0;
  }

  :global(.results) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1.5rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--line);
  }

  @media (max-width: 560px) {
    :global(.results) {
      grid-template-columns: 1fr;
    }
  }

  :global(.result-col) {
    text-align: center;
  }

  :global(.result-col h3) {
    margin: 0;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  :global(.result-value) {
    margin: 0.35rem 0 0;
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--ink);
  }

  :global(.disclaimer) {
    margin: 1.2rem 0 0;
    font-size: 0.8rem;
    line-height: 1.5;
    color: var(--muted);
  }
</style>
