---
import LoanCalculator from "../../components/LoanCalculator";
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Loan Calculator - AlfursanAuto.ca"
  description="Estimate your monthly car loan payments with our free calculator. Adjust price, interest rate, term, and down payment."
>
  <main class="container">
    <section class="calculator-shell">
      <section class="heading">
        <h2>Loan Calculator</h2>
      </section>

      <LoanCalculator client:load />
    </section>
  </main>
</Layout>

<style>
  .container {
    max-width: 1466px;
    margin: 0 auto;
    padding: 2rem 30px 4rem;
  }

  .calculator-shell {
    background: #dfe2ea;
    border-radius: 24px;
    padding: clamp(1rem, 2vw, 2rem);
  }

  .heading {
    margin-bottom: 1.3rem;
  }

  h2 {
    margin: 0;
    text-align: center;
    color: #1f2434;
    line-height: 1.03;
    font-size: clamp(2.6rem, 7vw, 5rem);
  }

  :global(.calc-wrapper) {
    max-width: 980px;
    margin: 0 auto;
    background: #f3f4f6;
    border: 1px solid #d2d7e2;
    border-radius: 18px;
    padding: clamp(1.2rem, 2.2vw, 2rem);
    box-shadow: none;
  }

  :global(.calc-intro p) {
    max-width: 70ch;
    margin: 0 auto 1.4rem;
    color: #4f5662;
    text-align: center;
    font-size: 1.03rem;
    line-height: 1.55;
  }

  :global(.calc-fields) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 560px) {
    :global(.calc-fields) {
      grid-template-columns: 1fr;
    }
  }

  :global(.calc-fields label) {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    font-weight: 600;
    font-size: 0.95rem;
    color: #313b4f;
  }

  :global(.required) {
    color: var(--brand-red);
  }

  :global(.calc-fields .label-text) {
    font-size: 0.95rem;
  }

  :global(.calc-fields input) {
    border: 1px solid #bac3cf;
    border-radius: 12px;
    padding: 0.72rem 0.8rem;
    font-size: 1.05rem;
    color: #2a3040;
    background: #fff;
    width: 100%;
  }

  :global(.input-with-suffix) {
    display: flex;
    align-items: center;
    border: 1px solid #bac3cf;
    border-radius: 12px;
    background: #fff;
    overflow: hidden;
  }

  :global(.input-with-suffix input) {
    border: none;
    border-radius: 0;
    flex: 1;
  }

  :global(.suffix),
  :global(.prefix) {
    padding: 0 0.75rem;
    color: #8f99a9;
    font-weight: 700;
    font-size: 1.05rem;
    flex-shrink: 0;
    background: #f3f5f9;
    height: 100%;
    display: inline-flex;
    align-items: center;
  }

  :global(.prefix) {
    border-right: 1px solid #d1d7e0;
  }

  :global(.suffix) {
    border-left: 1px solid #d1d7e0;
  }

  :global(.prefix.icon-prefix) {
    color: #cc2e1f;
    font-size: 1.2rem;
  }

  :global(.suffix.icon-suffix) {
    color: #cc2e1f;
  }

  :global(.icon-price),
  :global(.icon-period) {
    font-size: 1.32rem;
    font-weight: 800;
    line-height: 1;
  }

  :global(.results) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid #d2d7e2;
    border-bottom: 1px solid #cb3e32;
    border-left: 1px solid #cb3e32;
    border-right: 1px solid #cb3e32;
    border-radius: 22px;
    overflow: hidden;
  }

  @media (max-width: 560px) {
    :global(.results) {
      grid-template-columns: 1fr;
    }

    :global(.result-col + .result-col) {
      border-top: 1px solid #d5dae3;
    }
  }

  :global(.result-col) {
    text-align: center;
    padding: 1.1rem 0.8rem;
  }

  :global(.result-col + .result-col) {
    border-left: 1px solid #d5dae3;
  }

  :global(.result-col h3) {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 600;
    color: #8e98a8;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  :global(.result-value) {
    margin: 0.45rem 0 0;
    font-size: 2rem;
    font-weight: 800;
    color: var(--ink);
  }

  :global(.result-value.placeholder) {
    color: #cb3e32;
  }

  :global(.disclaimer) {
    margin: 1.2rem 0 0;
    text-align: center;
    font-size: 0.95rem;
    line-height: 1.5;
    color: #6f7787;
  }

  @media (max-width: 1024px) {
    :global(.calc-fields .label-text) {
      font-size: 0.95rem;
    }

    :global(.calc-fields input) {
      font-size: 1rem;
    }

    :global(.result-col h3) {
      font-size: 1rem;
    }

    :global(.result-value) {
      font-size: 1.4rem;
    }

    :global(.disclaimer) {
      font-size: 0.86rem;
    }
  }

  @media (max-width: 640px) {
    .calculator-shell {
      border-radius: 20px;
      padding: 1.2rem 0.9rem 1.6rem;
    }

    h2 {
      max-width: 11ch;
      margin: 0 auto;
      font-size: clamp(2.45rem, 9vw, 4rem);
    }

    :global(.calc-wrapper) {
      background: transparent;
      border: none;
      padding: 0;
    }

    :global(.calc-fields .label-text) {
      font-size: 1.15rem;
    }

    :global(.calc-fields input) {
      font-size: 1.2rem;
    }

    :global(.suffix),
    :global(.prefix) {
      font-size: 1.2rem;
    }
  }
</style>
