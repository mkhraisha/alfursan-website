---
import LoanCalculator from "../../components/LoanCalculator";
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Loan Calculator - AlfursanAuto.ca"
  description="Estimate your monthly car loan payments with our free calculator. Adjust price, interest rate, term, and down payment."
>
  <main class="container">
    <section class="calculator-shell">
      <section class="heading">
        <h2>Loan Calculator</h2>
      </section>

      <LoanCalculator client:load />
    </section>
  </main>
</Layout>

<style>
  .container {
    max-width: 1466px;
    margin: 0 auto;
    padding: 2rem 15px 4rem;
  }

  .calculator-shell {
    background: #f2f5fb;
    border-radius: 20px;
    padding: 3.125rem 0 4.375rem;
  }

  .heading {
    margin-bottom: 2.5rem;
  }

  h2 {
    margin: 0;
    text-align: center;
    color: var(--ink);
    line-height: 1.1;
    font-size: 3.125rem;
    font-weight: 900;
  }

  :global(.calc-wrapper) {
    max-width: 980px;
    margin: 0 auto;
    background: transparent;
    border: none;
    border-radius: 0;
    padding: 0 0.9375rem;
    box-shadow: none;
  }

  :global(.calc-intro p) {
    max-width: 70ch;
    margin: 0 auto 1.75rem;
    color: #4f5662;
    text-align: center;
    font-size: 1rem;
    line-height: 1.6;
  }

  :global(.calc-fields) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 560px) {
    :global(.calc-fields) {
      grid-template-columns: 1fr;
    }
  }

  :global(.calc-fields label) {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    font-weight: 600;
    font-size: 0.95rem;
    color: #313b4f;
  }

  :global(.required) {
    color: var(--brand-red);
  }

  :global(.calc-fields .label-text) {
    font-size: 0.95rem;
  }

  :global(.calc-fields input) {
    border: 1px solid #e7edf3;
    border-radius: 10px;
    padding: 0.625rem 1.6875rem 0.625rem 4.3125rem;
    font-size: 0.875rem;
    font-weight: 700;
    color: #000;
    background: #fff;
    width: 100%;
  }

  :global(.input-with-suffix) {
    display: flex;
    align-items: center;
    border: 1px solid #e7edf3;
    border-radius: 10px;
    background: #fff;
    overflow: hidden;
  }

  :global(.input-with-suffix input) {
    border: none;
    border-radius: 0;
    flex: 1;
    padding: 0.625rem 0.75rem;
  }

  :global(.suffix),
  :global(.prefix) {
    padding: 0 0.75rem;
    color: #8f99a9;
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
    background: #f3f5f9;
    height: 100%;
    display: inline-flex;
    align-items: center;
  }

  :global(.prefix) {
    border-right: 1px solid #e7edf3;
  }

  :global(.suffix) {
    border-left: 1px solid #e7edf3;
  }

  :global(.prefix.icon-prefix) {
    color: var(--brand-red);
    font-size: 1.1rem;
  }

  :global(.suffix.icon-suffix) {
    color: var(--brand-red);
  }

  :global(.icon-price),
  :global(.icon-period) {
    font-size: 1.1rem;
    font-weight: 800;
    line-height: 1;
  }

  /* Horizontal separator between form and results */
  :global(.calc-separator) {
    height: 1px;
    background: #e7e9ee;
    margin: 2.5rem 0 4rem;
  }

  :global(.results) {
    display: flex;
    max-width: 800px;
    margin: 0 auto;
    border: 1px solid var(--brand-red);
    border-radius: 20px;
    overflow: hidden;
    background: #fff;
  }

  @media (max-width: 560px) {
    :global(.results) {
      flex-direction: column;
    }

    :global(.result-col + .result-col) {
      border-top: 1px solid #e7e9ee;
      border-left: none;
    }
  }

  :global(.result-col) {
    text-align: center;
    padding: 0 2.1875rem;
    flex: 1;
  }

  :global(.result-col + .result-col) {
    border-left: 1px solid #e7e9ee;
  }

  :global(.result-col h3) {
    margin: 1.875rem 0 0.5rem;
    font-size: 1.1875rem;
    font-weight: 600;
    color: var(--ink);
    text-transform: none;
    letter-spacing: normal;
  }

  :global(.result-value) {
    margin: 0 0 2.25rem;
    font-size: 1.1875rem;
    font-weight: 700;
    color: var(--brand-red);
  }

  :global(.result-value.placeholder) {
    color: var(--brand-red);
  }

  :global(.disclaimer) {
    margin: 1.5rem 0 0;
    text-align: center;
    font-size: 0.875rem;
    line-height: 1.55;
    color: #6f7787;
  }

  @media (max-width: 1024px) {
    h2 {
      font-size: 2.8rem;
    }

    :global(.calc-fields .label-text) {
      font-size: 0.95rem;
    }

    :global(.calc-fields input) {
      font-size: 0.9rem;
    }

    :global(.result-col h3) {
      font-size: 1rem;
    }

    :global(.result-value) {
      font-size: 1rem;
    }

    :global(.disclaimer) {
      font-size: 0.82rem;
    }
  }

  @media (max-width: 640px) {
    .calculator-shell {
      border-radius: 20px;
      padding: 2rem 0 2.5rem;
    }

    h2 {
      font-size: clamp(2rem, 9vw, 3rem);
    }

    :global(.calc-wrapper) {
      padding: 0 1rem;
    }

    :global(.results) {
      max-width: 100%;
    }

    :global(.result-col) {
      padding: 0 1rem;
    }
  }
</style>
