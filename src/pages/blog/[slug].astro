---
import Layout from "../../layouts/Layout.astro";
import { getPosts, getPostBySlug } from "../../lib/wordpress";
import type { BlogPost } from "../../lib/wordpress";

export async function getStaticPaths() {
  const posts = await getPosts(100);
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = await getPostBySlug(slug!);

if (!post) {
  return Astro.redirect("/blog/");
}

const formatDate = (iso: string): string => {
  const d = new Date(iso);
  return d.toLocaleDateString("en-CA", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.title,
  url: `https://alfursanauto.ca/blog/${post.slug}/`,
  image: post.featuredImage,
  datePublished: post.date,
  dateModified: post.modified,
  description: post.excerpt,
  publisher: {
    "@type": "Organization",
    name: "Alfursan Auto",
    logo: {
      "@type": "ImageObject",
      url: "https://alfursanauto.ca/wp-content/uploads/2025/06/al-fursan-logo-transparent.png",
    },
  },
};
---

<Layout
  title={`${post.title} | Alfursan Auto Blog`}
  description={post.excerpt}
  image={post.featuredImage}
  schema={articleSchema}
>
  <main class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Homepage</a>
      <span class="sep">&rsaquo;</span>
      <a href="/blog/">Blog</a>
      <span class="sep">&rsaquo;</span>
      <span>{post.title}</span>
    </nav>

    <article class="post">
      {
        post.featuredImage && (
          <div class="hero-image">
            <img src={post.featuredImage} alt={post.title} />
          </div>
        )
      }

      <header class="post-header">
        <time datetime={post.date}>{formatDate(post.date)}</time>
        <h1>{post.title}</h1>
      </header>

      <div class="post-content" set:html={post.htmlContent} />
    </article>

    <nav class="post-nav">
      <a href="/blog/">&larr; Back to all articles</a>
    </nav>
  </main>
</Layout>

<style>
  .container {
    max-width: 820px;
    margin: 0 auto;
    padding: 2rem 30px 4rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 1.2rem;
    font-size: 0.85rem;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--brand-red);
    text-decoration: none;
    font-weight: 600;
  }

  .breadcrumb .sep {
    color: var(--muted);
  }

  .breadcrumb span:last-child {
    color: var(--muted);
  }

  .post {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 14px;
    overflow: hidden;
  }

  .hero-image {
    width: 100%;
    aspect-ratio: 16 / 8;
    overflow: hidden;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .post-header {
    padding: 1.8rem 2rem 0;
  }

  .post-header time {
    font-size: 0.8rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 600;
  }

  .post-header h1 {
    margin: 0.5rem 0 0;
    font-size: clamp(1.5rem, 3.5vw, 2.2rem);
    line-height: 1.25;
    color: var(--ink);
  }

  .post-content {
    padding: 1.4rem 2rem 2.2rem;
    font-size: 1.02rem;
    line-height: 1.8;
    color: var(--detail-body, var(--ink));
  }

  .post-content :global(h2),
  .post-content :global(h3),
  .post-content :global(h4),
  .post-content :global(h5),
  .post-content :global(h6) {
    margin: 1.6rem 0 0.6rem;
    color: var(--ink);
  }

  .post-content :global(p) {
    margin: 0 0 1rem;
  }

  .post-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1rem 0;
  }

  .post-content :global(blockquote) {
    border-left: 4px solid var(--brand-red);
    margin: 1.2rem 0;
    padding: 0.6rem 1.2rem;
    color: var(--muted-dark, var(--ink));
    font-style: italic;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    padding-left: 1.4rem;
    margin: 0.8rem 0;
  }

  .post-content :global(li) {
    margin-bottom: 0.35rem;
  }

  .post-content :global(a) {
    color: var(--brand-red);
    text-decoration: underline;
  }

  .post-nav {
    margin-top: 2rem;
    text-align: center;
  }

  .post-nav a {
    display: inline-block;
    padding: 0.7rem 1.6rem;
    font-weight: 700;
    font-size: 0.92rem;
    color: var(--brand-red);
    text-decoration: none;
    border: 2px solid var(--brand-red);
    border-radius: 999px;
    transition:
      background 0.2s,
      color 0.2s;
  }

  .post-nav a:hover {
    background: var(--brand-red);
    color: #fff;
  }

  @media (max-width: 640px) {
    .post-header {
      padding: 1.2rem 1rem 0;
    }

    .post-content {
      padding: 1rem 1rem 1.6rem;
    }
  }
</style>
