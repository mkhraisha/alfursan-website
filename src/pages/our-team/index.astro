---
import Layout from "../../layouts/Layout.astro";

const stats = [
  { value: "15+", label: "Years in Business" },
  { value: "158", label: "Specialists" },
  { value: "50k+", label: "Cars Sold" },
  { value: "8", label: "Locations" },
];
---

<Layout
  title="Our Team | Alfursan Auto"
  description="Meet the Alfursan Auto team. We've been proudly serving our community for over 15 years, helping you find a car that fits your needs and budget."
>
  <main class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Homepage</a>
      <span class="sep">&rsaquo;</span>
      <span>Our Team</span>
    </nav>

    <section class="heading">
      <p class="kicker">Our Team</p>
      <h1>Meet Our Team</h1>
    </section>

    <section class="intro-card">
      <h2>We've been proudly serving our community for over 15 years</h2>
      <p>
        We know how difficult it can be to find your dream car, and our team of
        experts are dedicated to helping you find a model that not only
        interests you but fits with your budget.
      </p>
    </section>

    <section class="stats-row">
      {
        stats.map((stat) => (
          <div class="stat">
            <span class="stat-value">{stat.value}</span>
            <span class="stat-label">{stat.label}</span>
          </div>
        ))
      }
    </section>

    <section class="cta-card">
      <h2>Have a question?</h2>
      <p>
        Our team is ready to answer any questions you have. Get in touch with us
        today.
      </p>
      <div class="cta-buttons">
        <a href="/contact-us/" class="btn btn-primary">Contact Us</a>
        <a href="tel:+14168384007" class="btn btn-outline"
          >Call +1 (416) 838-4007</a
        >
      </div>
    </section>
  </main>
</Layout>

<style>
  .container {
    max-width: 1466px;
    margin: 0 auto;
    padding: 2rem 30px 4rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
    font-size: 0.85rem;
  }

  .breadcrumb a {
    color: var(--brand-red);
    text-decoration: none;
    font-weight: 600;
  }

  .breadcrumb .sep {
    color: var(--muted);
  }

  .breadcrumb span:last-child {
    color: var(--muted);
  }

  .heading {
    background: var(--dark);
    color: #fff;
    border-radius: 16px;
    padding: 1.2rem;
    margin-bottom: 2rem;
  }

  .kicker {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: var(--subtitle-on-dark);
    text-transform: uppercase;
  }

  h1 {
    margin: 0.35rem 0 0;
    font-size: clamp(1.45rem, 3.3vw, 2.2rem);
  }

  .intro-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 2rem 2.2rem;
    margin-bottom: 2rem;
    box-shadow: 0 10px 24px rgba(16, 24, 40, 0.05);
  }

  .intro-card h2 {
    margin: 0 0 0.8rem;
    font-size: 1.45rem;
    line-height: 1.35;
    color: var(--ink);
  }

  .intro-card p {
    margin: 0;
    line-height: 1.75;
    color: var(--muted-dark, var(--ink));
    font-size: 1.05rem;
    max-width: 700px;
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.2rem;
    margin-bottom: 2rem;
  }

  .stat {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 1.6rem 1rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .stat-value {
    font-size: 2.4rem;
    font-weight: 800;
    color: var(--brand-red);
    line-height: 1.1;
  }

  .stat-label {
    font-size: 0.88rem;
    color: var(--muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .cta-card {
    background: var(--dark);
    color: #fff;
    border-radius: 14px;
    padding: 2rem 2.2rem;
    text-align: center;
  }

  .cta-card h2 {
    margin: 0 0 0.5rem;
    font-size: 1.5rem;
  }

  .cta-card p {
    margin: 0 0 1.4rem;
    color: var(--subtitle-on-dark);
  }

  .cta-buttons {
    display: flex;
    gap: 0.8rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-block;
    padding: 0.75rem 1.8rem;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.92rem;
    text-decoration: none;
    transition:
      background 0.2s,
      color 0.2s;
  }

  .btn-primary {
    background: var(--brand-red);
    color: #fff;
  }

  .btn-primary:hover {
    opacity: 0.9;
  }

  .btn-outline {
    border: 2px solid #fff;
    color: #fff;
  }

  .btn-outline:hover {
    background: #fff;
    color: var(--dark);
  }

  @media (max-width: 640px) {
    .stats-row {
      grid-template-columns: repeat(2, 1fr);
    }

    .intro-card {
      padding: 1.4rem;
    }

    .cta-card {
      padding: 1.4rem;
    }
  }
</style>
