---
import Layout from "../../layouts/Layout.astro";
import { getContactPageContent } from "../../lib/wordpress";

type FetchState = "ok" | "not-found" | "error";

const fallbackIntro =
  "Alfursan Auto is a trusted used car dealership based in the Greater Toronto Area, specializing in retail sales, wholesale deals, and international vehicle exports.";
const fallbackAddress = "5866 Mayfield Rd, Caledon, ON L7C 0Z6";
const fallbackMapHref =
  "https://maps.google.com/?q=5866+Mayfield+Rd%2C+Caledon%2C+ON+L7C+0Z6";
const fallbackPhone = "+1 (416) 838-4007";
const fallbackEmail = "sales@alfursanauto.ca";
const fallbackSocialLinks = [
  {
    href: "https://www.facebook.com/people/Alfursan-Auto-Exports/61576687765706/",
    label: "Facebook",
  },
  {
    href: "https://www.instagram.com/alfursanauto/",
    label: "Instagram",
  },
];

const labelForSocialLink = (href: string): string => {
  if (/instagram/i.test(href)) return "Instagram";
  if (/facebook/i.test(href)) return "Facebook";
  if (/x\.com|twitter/i.test(href)) return "X";
  return "Social";
};

let fetchState: FetchState = "ok";
let introText = fallbackIntro;
let address = fallbackAddress;
let mapHref = fallbackMapHref;
let phone = fallbackPhone;
let email = fallbackEmail;
let socialLinks = fallbackSocialLinks;

try {
  const contact = await getContactPageContent();
  if (contact.page) {
    introText = contact.page.excerpt || fallbackIntro;
    address = contact.address || fallbackAddress;
    mapHref = contact.mapUrl || fallbackMapHref;
    phone = contact.phone || fallbackPhone;
    email = contact.email || fallbackEmail;
    if (contact.socialLinks.length > 0) {
      socialLinks = contact.socialLinks.map((href) => ({
        href,
        label: labelForSocialLink(href),
      }));
    }
  } else {
    fetchState = "not-found";
  }
} catch (error) {
  fetchState = "error";
  console.error(
    "[contact-us] Failed to load contact content from WordPress",
    error,
  );
}
---

<Layout
  title="Contact Us | Alfursan Auto"
  description="Get in touch with Alfursan Auto — a trusted used car dealership in the Greater Toronto Area. Call, email, or visit us today."
>
  <main class="container">
    {
      fetchState !== "ok" && (
        <p class="cms-status" role="status">
          {fetchState === "error"
            ? "Live contact content could not be loaded right now. Showing fallback content."
            : "Live contact content is not available. Showing fallback content."}
        </p>
      )
    }

    <div class="page-grid">
      <!-- Contact info column -->
      <div class="info-col">
        <h1>Contact us</h1>
        <p class="intro">{introText}</p>

        <p class="address-text">
          <a href={mapHref} target="_blank" rel="noreferrer">{address}</a>
        </p>

        <a href={`tel:${phone}`} class="phone-display">{phone}</a>

        <div class="email-row">
          <svg
            class="email-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="2" y="4" width="20" height="16" rx="2"></rect>
            <polyline points="2,4 12,13 22,4"></polyline>
          </svg>
          <a href={`mailto:${email}`}>{email}</a>
        </div>

        <div class="social-row">
          <span class="follow-label">Follow us</span>
          <div class="social-icons">
            {
              socialLinks.map((social) => {
                const isInstagram = /instagram/i.test(social.href);
                const isTwitter = /x\.com|twitter/i.test(social.href);
                return (
                  <a
                    href={social.href}
                    target="_blank"
                    rel="noreferrer"
                    class="social-btn"
                    aria-label={social.label}
                  >
                    {isInstagram ? (
                      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                      </svg>
                    ) : isTwitter ? (
                      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                      </svg>
                    ) : (
                      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                      </svg>
                    )}
                  </a>
                );
              })
            }
          </div>
        </div>
      </div>

      <!-- Form card -->
      <div class="form-card">
        <form
          class="contact-form"
          action="https://formsubmit.co/sales@alfursanauto.ca"
          method="POST"
        >
          <input type="text" name="_honey" style="display:none" />
          <input type="hidden" name="_captcha" value="false" />
          <input
            type="hidden"
            name="_next"
            value="https://alfursanauto.ca/contact-us/?sent=1"
          />
          <div class="fields-row">
            <input type="text" name="name" required placeholder="Name" />
            <input type="email" name="email" required placeholder="Email*" />
            <input type="tel" name="phone" placeholder="Phone" />
          </div>
          <textarea
            name="message"
            rows="10"
            required
            placeholder="Message*"></textarea>
          <div class="form-footer">
            <label class="privacy-label">
              <input type="checkbox" name="privacy" required />
              I accept the privacy policy
            </label>
            <button type="submit">Send</button>
          </div>
        </form>
      </div>
    </div>

    <section class="map-section">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2872.0!2d-79.8683!3d43.7761!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x882b15d3c4e7b6e7%3A0x0!2s5866+Mayfield+Rd%2C+Caledon%2C+ON+L7C+0Z6!5e0!3m2!1sen!2sca!4v1"
        width="100%"
        height="548"
        style="border:0; display:block;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Alfursan Auto location map"></iframe>
    </section>
  </main>
</Layout>

<style>
  .container {
    max-width: 1428px;
    margin: 0 auto;
    padding: 73px 30px 4rem;
  }

  .cms-status {
    margin: 0 0 1.5rem;
    padding: 0.75rem 0.9rem;
    border-radius: 10px;
    border: 1px solid #f2d6a1;
    background: #fff4dd;
    color: #7a4d00;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  /* Two-column page grid */
  .page-grid {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: 2.5rem;
    align-items: start;
    margin-bottom: 2.5rem;
  }

  /* Info column — no card, no border */
  .info-col {
    padding-top: 0.25rem;
  }

  h1 {
    font-size: 50px;
    font-weight: 900;
    color: var(--ink);
    margin: 0 0 1rem;
    line-height: 1.1;
  }

  .intro {
    font-size: 0.93rem;
    line-height: 1.7;
    color: var(--ink);
    margin: 0 0 1.4rem;
  }

  .address-text {
    font-size: 0.9rem;
    color: var(--ink);
    margin: 0 0 1rem;
    line-height: 1.5;
  }

  .address-text a {
    color: var(--ink);
    text-decoration: none;
  }

  .address-text a:hover {
    color: var(--brand-red);
  }

  /* Large red phone number */
  .phone-display {
    display: block;
    font-size: 30px;
    font-weight: 900;
    color: var(--brand-red);
    text-decoration: none;
    margin-bottom: 0.75rem;
    line-height: 1.2;
  }

  .phone-display:hover {
    opacity: 0.85;
  }

  /* Email row with icon */
  .email-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
  }

  .email-icon {
    width: 16px;
    height: 16px;
    color: var(--brand-red);
    flex-shrink: 0;
  }

  .email-row a {
    color: var(--ink);
    text-decoration: none;
    font-size: 0.9rem;
  }

  .email-row a:hover {
    color: var(--brand-red);
  }

  /* Social icon circles */
  .social-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .follow-label {
    font-size: 0.85rem;
    color: var(--muted);
    white-space: nowrap;
  }

  .social-icons {
    display: flex;
    gap: 0.45rem;
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--ink);
    color: #fff;
    text-decoration: none;
    transition: opacity 0.15s;
    flex-shrink: 0;
  }

  .social-btn:hover {
    opacity: 0.75;
  }

  .social-btn svg {
    width: 15px;
    height: 15px;
  }

  /* Form card — gray background */
  .form-card {
    background: #d8d8d8;
    border-radius: 14px;
    padding: 1.6rem;
  }

  .contact-form {
    display: grid;
    gap: 0.8rem;
  }

  /* Three-column row for name / email / phone */
  .fields-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0.6rem;
  }

  .contact-form input,
  .contact-form textarea {
    border: 1px solid #e7edf3;
    border-radius: 6px;
    padding: 0.6rem 0.75rem;
    font: inherit;
    font-size: 0.9rem;
    background: #fff;
    width: 100%;
    box-sizing: border-box;
    color: var(--ink);
  }

  .contact-form input::placeholder,
  .contact-form textarea::placeholder {
    color: #aaa;
  }

  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: 2px solid var(--brand-red);
    outline-offset: -1px;
    border-color: var(--brand-red);
  }

  .contact-form textarea {
    resize: vertical;
  }

  /* Footer row: checkbox left, Send button right */
  .form-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .privacy-label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--ink);
    cursor: pointer;
    flex: 1;
  }

  .privacy-label input[type="checkbox"] {
    width: auto;
    padding: 0;
    border: none;
    flex-shrink: 0;
    accent-color: var(--brand-red);
  }

  .contact-form button[type="submit"] {
    border: 0;
    background: var(--brand-red);
    color: #fff;
    border-radius: 8px;
    padding: 0.6rem 1.8rem;
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    transition: opacity 0.15s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .contact-form button[type="submit"]:hover {
    opacity: 0.9;
  }

  /* Map — full width, taller, no radius */
  .map-section {
    margin-bottom: 1rem;
  }

  @media (max-width: 900px) {
    .page-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .fields-row {
      grid-template-columns: 1fr;
    }

    .form-footer {
      flex-direction: column;
      align-items: flex-start;
    }

    .contact-form button[type="submit"] {
      width: 100%;
    }
  }
</style>
