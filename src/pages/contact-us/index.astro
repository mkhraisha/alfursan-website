---
import Layout from "../../layouts/Layout.astro";
import { getContactPageContent } from "../../lib/wordpress";

type FetchState = "ok" | "not-found" | "error";

const fallbackIntro =
  "Alfursan Auto is a trusted used car dealership based in the Greater Toronto Area, specializing in retail sales, wholesale deals, and international vehicle exports.";
const fallbackAddress = "5866 Mayfield Rd, Caledon, ON L7C 0Z6";
const fallbackMapHref =
  "https://maps.google.com/?q=5866+Mayfield+Rd%2C+Caledon%2C+ON+L7C+0Z6";
const fallbackPhone = "+1 (416) 838-4007";
const fallbackEmail = "sales@alfursanauto.ca";
const fallbackSocialLinks = [
  {
    href: "https://www.facebook.com/people/Alfursan-Auto-Exports/61576687765706/",
    label: "Facebook",
  },
  {
    href: "https://www.instagram.com/alfursanauto/",
    label: "Instagram",
  },
];

const labelForSocialLink = (href: string): string => {
  if (/instagram/i.test(href)) return "Instagram";
  if (/facebook/i.test(href)) return "Facebook";
  if (/x\.com|twitter/i.test(href)) return "X";
  return "Social";
};

let fetchState: FetchState = "ok";
let introText = fallbackIntro;
let address = fallbackAddress;
let mapHref = fallbackMapHref;
let phone = fallbackPhone;
let email = fallbackEmail;
let socialLinks = fallbackSocialLinks;

try {
  const contact = await getContactPageContent();
  if (contact.page) {
    introText = contact.page.excerpt || fallbackIntro;
    address = contact.address || fallbackAddress;
    mapHref = contact.mapUrl || fallbackMapHref;
    phone = contact.phone || fallbackPhone;
    email = contact.email || fallbackEmail;
    if (contact.socialLinks.length > 0) {
      socialLinks = contact.socialLinks.map((href) => ({
        href,
        label: labelForSocialLink(href),
      }));
    }
  } else {
    fetchState = "not-found";
  }
} catch (error) {
  fetchState = "error";
  console.error(
    "[contact-us] Failed to load contact content from WordPress",
    error,
  );
}
---

<Layout
  title="Contact Us | Alfursan Auto"
  description="Get in touch with Alfursan Auto — a trusted used car dealership in the Greater Toronto Area. Call, email, or visit us today."
>
  <main class="container">
    {
      fetchState !== "ok" && (
        <p class="cms-status" role="status">
          {fetchState === "error"
            ? "Live contact content could not be loaded right now. Showing fallback content."
            : "Live contact content is not available. Showing fallback content."}
        </p>
      )
    }

    <section class="heading">
      <p class="kicker">Contact</p>
      <h1>Contact us</h1>
    </section>

    <div class="two-col">
      <article class="content-card">
        <h2>Get in Touch</h2>
        <p class="intro">{introText}</p>

        <div class="contact-info">
          <div class="info-item">
            <strong>Address</strong>
            <a href={mapHref} target="_blank" rel="noreferrer">{address}</a>
          </div>
          <div class="info-item">
            <strong>Phone</strong>
            <a href={`tel:${phone}`}>{phone}</a>
          </div>
          <div class="info-item">
            <strong>Email</strong>
            <a href={`mailto:${email}`}>{email}</a>
          </div>
          <div class="info-item">
            <strong>Follow Us</strong>
            <div class="social">
              {
                socialLinks.map((social) => (
                  <a href={social.href} target="_blank" rel="noreferrer">
                    {social.label}
                  </a>
                ))
              }
            </div>
          </div>
        </div>
      </article>

      <article class="content-card">
        <h2>Send Us a Message</h2>
        <form
          class="contact-form"
          action="https://formsubmit.co/sales@alfursanauto.ca"
          method="POST"
        >
          <input type="text" name="_honey" style="display:none" />
          <input type="hidden" name="_captcha" value="false" />
          <input
            type="hidden"
            name="_next"
            value="https://alfursanauto.ca/contact-us/?sent=1"
          />
          <label>
            Name
            <input type="text" name="name" required placeholder="Your name" />
          </label>
          <label>
            Email
            <input
              type="email"
              name="email"
              required
              placeholder="your@email.com"
            />
          </label>
          <label>
            Phone
            <input type="tel" name="phone" placeholder="+1 (___) ___-____" />
          </label>
          <label>
            Message
            <textarea
              name="message"
              rows="5"
              required
              placeholder="How can we help you?"></textarea>
          </label>
          <label class="checkbox-label">
            <input type="checkbox" name="privacy" required />
            I accept the privacy policy
          </label>
          <button type="submit">Send Message</button>
        </form>
      </article>
    </div>

    <section class="map-section">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2872.0!2d-79.8683!3d43.7761!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x882b15d3c4e7b6e7%3A0x0!2s5866+Mayfield+Rd%2C+Caledon%2C+ON+L7C+0Z6!5e0!3m2!1sen!2sca!4v1"
        width="100%"
        height="400"
        style="border:0; border-radius:14px;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Alfursan Auto location map"></iframe>
    </section>
  </main>
</Layout>

<style>
  .container {
    max-width: 1466px;
    margin: 0 auto;
    padding: 2rem 30px 4rem;
  }

  .cms-status {
    margin: 0 0 1rem;
    padding: 0.75rem 0.9rem;
    border-radius: 10px;
    border: 1px solid #f2d6a1;
    background: #fff4dd;
    color: #7a4d00;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .heading {
    background: var(--dark);
    color: #fff;
    border-radius: 16px;
    padding: 1.1rem;
    margin-bottom: 1.5rem;
  }

  .kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.8rem;
    color: var(--subtitle-on-dark);
    font-weight: 800;
  }

  h1 {
    margin: 0.35rem 0 0;
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .content-card {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 1.6rem;
    box-shadow: 0 10px 24px rgba(16, 24, 40, 0.05);
  }

  .content-card h2 {
    margin: 0 0 0.8rem;
    font-size: 1.35rem;
  }

  .intro {
    margin: 0 0 1.4rem;
    line-height: 1.7;
    color: var(--muted-dark, var(--ink));
  }

  .contact-info {
    display: grid;
    gap: 1rem;
  }

  .info-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .info-item strong {
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted);
  }

  .info-item a {
    color: var(--ink);
    text-decoration: none;
    font-weight: 600;
  }

  .info-item a:hover {
    color: var(--brand-red);
  }

  .social {
    display: flex;
    gap: 0.8rem;
  }

  .contact-form {
    display: grid;
    gap: 0.9rem;
  }

  .contact-form label {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--filter-label, var(--ink));
  }

  .contact-form input,
  .contact-form textarea {
    border: 1px solid var(--input-border);
    border-radius: 8px;
    padding: 0.6rem 0.7rem;
    font: inherit;
    font-size: 0.95rem;
  }

  .contact-form textarea {
    resize: vertical;
  }

  .checkbox-label {
    flex-direction: row !important;
    align-items: center;
    gap: 0.5rem !important;
    font-size: 0.9rem;
    cursor: pointer;
  }

  .checkbox-label input[type="checkbox"] {
    width: auto;
    margin: 0;
  }

  .contact-form button {
    border: 0;
    background: var(--brand-red);
    color: #fff;
    border-radius: 10px;
    padding: 0.7rem 1.4rem;
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .contact-form button:hover {
    opacity: 0.9;
  }

  .map-section {
    margin-bottom: 1rem;
  }

  @media (max-width: 768px) {
    .two-col {
      grid-template-columns: 1fr;
    }

    .content-card {
      padding: 1.2rem;
    }
  }
</style>
