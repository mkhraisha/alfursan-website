---
import InventoryFilters from "../../components/InventoryFilters";
import Layout from "../../layouts/Layout.astro";
import { getCars } from "../../lib/wordpress";

const cars = await getCars(100);
---

<Layout
  title="Listings | Alfursan Auto"
  description="Browse available vehicles at Alfursan Auto."
>
  <main class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Homepage</a>
      <span class="sep">&rsaquo;</span>
      <span>Search</span>
    </nav>
    <section class="heading">
      <p class="kicker">Inventory</p>
      <h1>Available Listings</h1>
      <p>
        Browse inspected vehicles and filter results to match your budget and
        preferences.
      </p>
    </section>
    <InventoryFilters cars={cars} client:load />
  </main>
</Layout>

<style>
  .container {
    max-width: 1468px;
    margin: 0 auto;
    padding: 2rem 30px 4rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.75rem;
    font-size: 0.85rem;
  }

  .breadcrumb a {
    color: var(--brand-red);
    text-decoration: none;
    font-weight: 600;
  }

  .breadcrumb .sep {
    color: var(--muted);
  }

  .breadcrumb span:last-child {
    color: var(--muted);
  }

  .heading {
    background: var(--dark);
    color: #fff;
    border-radius: 16px;
    padding: 1.2rem;
    margin-bottom: 1rem;
  }

  .kicker {
    margin: 0;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: var(--subtitle-on-dark);
    text-transform: uppercase;
  }

  h1 {
    margin: 0.35rem 0;
    font-size: clamp(1.45rem, 3.3vw, 2.2rem);
  }

  .heading p {
    margin: 0;
    color: var(--subtitle-on-dark);
  }

  :global(.filters) {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.8rem;
    margin-bottom: 0.9rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 0.9rem;
    box-shadow: 0 10px 24px rgba(16, 24, 40, 0.05);
  }

  :global(.filters label) {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--filter-label);
  }

  :global(.filters input),
  :global(.filters select) {
    border: 1px solid var(--input-border);
    border-radius: 8px;
    padding: 0.52rem 0.6rem;
    font-size: 0.92rem;
    background: #fff;
  }

  :global(.reset) {
    align-self: end;
    border: 1px solid var(--active-filter-border);
    background: var(--bg-active-filter);
    color: var(--active-filter-text);
    border-radius: 8px;
    padding: 0.52rem 0.6rem;
    font-weight: 700;
    cursor: pointer;
  }

  :global(.muted) {
    color: var(--meta);
    margin-bottom: 1.5rem;
  }

  :global(.grid) {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  }

  :global(.card) {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 10px 24px rgba(16, 24, 40, 0.05);
    transition: box-shadow 0.2s;
  }

  :global(.card:hover) {
    box-shadow: 0 14px 32px rgba(16, 24, 40, 0.1);
  }

  :global(.card-img-link) {
    display: block;
  }

  :global(.card img),
  :global(.placeholder) {
    display: block;
    width: 100%;
    height: 180px;
    object-fit: cover;
    background: var(--bg-placeholder);
  }

  :global(.placeholder) {
    display: grid;
    place-items: center;
    color: var(--placeholder);
    font-size: 0.9rem;
  }

  :global(.card-content) {
    padding: 0.9rem;
  }

  :global(.card-content h2) {
    font-size: 1rem;
    margin: 0 0 0.35rem;
    line-height: 1.35;
  }

  :global(.meta) {
    color: var(--meta);
    font-size: 0.92rem;
    margin: 0 0 0.4rem;
  }

  :global(.price) {
    margin: 0 0 0.5rem;
    font-weight: 800;
    font-size: 1.1rem;
  }

  :global(.card-title-link) {
    text-decoration: none;
    color: inherit;
  }

  :global(.card-specs) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  :global(.card-specs span) {
    font-size: 0.82rem;
    color: var(--muted);
  }

  :global(.card-specs span + span::before) {
    content: "";
    display: inline-block;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--muted);
    vertical-align: middle;
    margin-right: 0.5rem;
  }

  :global(.btn) {
    display: inline-block;
    text-decoration: none;
    background: var(--brand-red);
    color: #fff;
    border-radius: 9px;
    padding: 0.5rem 0.7rem;
    font-size: 0.92rem;
  }

  :global(.pagination) {
    margin-top: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  :global(.pagination button) {
    border: 1px solid var(--border-light);
    background: var(--surface);
    border-radius: 8px;
    padding: 0.42rem 0.62rem;
    font-size: 0.9rem;
    cursor: pointer;
  }

  :global(.pagination button:disabled) {
    opacity: 0.5;
    cursor: not-allowed;
  }

  :global(.pagination .pages) {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  :global(.pagination .pages button.active) {
    border-color: var(--brand-red);
    background: var(--brand-red);
    color: #fff;
    font-weight: 700;
  }

  @media (max-width: 940px) {
    :global(.filters) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    :global(.filters) {
      grid-template-columns: 1fr;
    }
  }
</style>
