---
import InventoryFilters from "../../components/InventoryFilters";
import Layout from "../../layouts/Layout.astro";
import { getCars } from "../../lib/wordpress";

const cars = await getCars(100);
---

<Layout
  title="Search | Alfursan Auto"
  description="Browse available vehicles at Alfursan Auto."
>
  <main class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href={import.meta.env.BASE_URL}>Homepage</a>
      <span class="sep">&rsaquo;</span>
      <span>Search</span>
    </nav>
    <InventoryFilters cars={cars} client:load />
  </main>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.25rem 24px 4rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 1rem;
    font-size: 0.85rem;
  }

  .breadcrumb a {
    color: var(--brand-red);
    text-decoration: none;
    font-weight: 600;
  }

  .breadcrumb .sep {
    color: var(--muted);
  }

  .breadcrumb span:last-child {
    color: var(--muted);
  }

  /* ── Filter bar ── */
  :global(.filters) {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1rem;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  :global(.filter-row) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    align-items: center;
  }

  :global(.filter-row select),
  :global(.filter-row input) {
    flex: 1 1 150px;
    min-width: 0;
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 0.85rem 1rem;
    font-size: 0.9rem;
    font-weight: 600;
    background: #fff;
    color: var(--ink);
    line-height: 1.4;
    appearance: auto;
    cursor: pointer;
    transition: border-color 0.15s;
  }

  :global(.filter-row select:hover),
  :global(.filter-row input:hover) {
    border-color: var(--brand-red);
  }

  :global(.filter-row select:focus),
  :global(.filter-row input:focus) {
    outline: none;
    border-color: var(--brand-red);
  }

  :global(.filter-actions) {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-left: auto;
    flex-shrink: 0;
  }

  :global(.reset) {
    background: none;
    border: none;
    color: var(--brand-red);
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    padding: 0.85rem 0.5rem;
    text-decoration: underline;
    white-space: nowrap;
  }

  :global(.more-filters-toggle) {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 0.85rem 1.1rem;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    color: var(--ink);
    white-space: nowrap;
    transition: border-color 0.15s, color 0.15s;
  }

  :global(.more-filters-toggle:hover) {
    border-color: var(--brand-red);
    color: var(--brand-red);
  }

  /* ── Extra filters ── */
  :global(.extra-filters) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    padding: 1rem 1.5rem;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 10px;
    margin-bottom: 1rem;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  :global(.extra-filters select) {
    flex: 1 1 155px;
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 0.85rem 1rem;
    font-size: 0.9rem;
    font-weight: 600;
    background: #fff;
    color: var(--ink);
    appearance: auto;
    cursor: pointer;
    transition: border-color 0.15s;
  }

  :global(.extra-filters select:hover) {
    border-color: var(--brand-red);
  }

  /* ── Results header ── */
  :global(.results-header) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.65rem;
  }

  :global(.results-count) {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--ink);
  }

  :global(.sort-group) {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.86rem;
  }

  :global(.sort-label) {
    color: var(--muted);
    white-space: nowrap;
  }

  :global(.sort-select) {
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 0.65rem 0.9rem;
    font-size: 0.9rem;
    font-weight: 600;
    background: #fff;
    color: var(--ink);
    appearance: auto;
    cursor: pointer;
    transition: border-color 0.15s;
  }

  :global(.sort-select:hover) {
    border-color: var(--brand-red);
  }

  /* ── Inventory list ── */
  :global(.inventory-list) {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--line);
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
  }

  :global(.car-row) {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--line);
    transition: background 0.12s;
  }

  :global(.car-row:last-child) {
    border-bottom: none;
  }

  :global(.car-row:hover) {
    background: #fafbfc;
  }

  :global(.car-thumb-link) {
    position: relative;
    flex-shrink: 0;
    display: block;
    line-height: 0;
  }

  :global(.car-thumb) {
    width: 155px;
    height: 104px;
    object-fit: cover;
    display: block;
    border-radius: 4px;
    background: #eee;
  }

  :global(.car-thumb-placeholder) {
    width: 155px;
    height: 104px;
    display: grid;
    place-items: center;
    background: #f0f0f2;
    color: #aaa;
    font-size: 0.78rem;
    border-radius: 4px;
  }

  :global(.car-details) {
    flex: 1;
    min-width: 0;
  }

  :global(.car-title) {
    font-size: 0.93rem;
    font-weight: 700;
    margin: 0 0 0.2rem;
    line-height: 1.35;
    color: var(--ink);
  }

  :global(.car-title-link) {
    text-decoration: none;
    color: inherit;
  }

  :global(.car-title-link:hover .car-title) {
    color: var(--brand-red);
  }

  :global(.car-subtitle) {
    font-size: 0.8rem;
    color: var(--muted);
    margin: 0 0 0.38rem;
  }

  :global(.car-tags) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  :global(.year-pill) {
    background: var(--brand-red);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.12rem 0.42rem;
    border-radius: 4px;
  }

  :global(.spec-pill) {
    background: #f0f0f2;
    color: var(--ink);
    font-size: 0.7rem;
    padding: 0.12rem 0.42rem;
    border-radius: 4px;
  }

  :global(.car-price-col) {
    flex-shrink: 0;
    text-align: right;
    min-width: 130px;
  }

  :global(.car-price) {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--brand-red);
    margin: 0 0 0.22rem;
  }

  :global(.financing-link) {
    font-size: 0.76rem;
    color: var(--muted);
    text-decoration: none;
    display: block;
  }

  :global(.financing-link:hover) {
    color: var(--brand-red);
    text-decoration: underline;
  }

  /* ── Badges (sold / img-count) ── */
  :global(.sold-badge) {
    position: absolute;
    top: 6px;
    left: 6px;
    background: var(--brand-red);
    color: #fff;
    font-size: 0.66rem;
    font-weight: 700;
    padding: 0.12rem 0.38rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  :global(.img-count) {
    position: absolute;
    bottom: 6px;
    right: 6px;
    background: rgba(0, 0, 0, 0.58);
    color: #fff;
    font-size: 0.66rem;
    font-weight: 700;
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
  }

  /* ── Pagination ── */
  :global(.pagination) {
    margin-top: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  :global(.pagination button) {
    border: 1px solid var(--line);
    background: #fff;
    border-radius: 6px;
    padding: 0.38rem 0.68rem;
    font-size: 0.88rem;
    cursor: pointer;
    min-width: 34px;
    transition: border-color 0.12s, color 0.12s;
  }

  :global(.pagination button:hover:not(:disabled)) {
    border-color: var(--brand-red);
    color: var(--brand-red);
  }

  :global(.pagination button:disabled) {
    opacity: 0.38;
    cursor: not-allowed;
  }

  :global(.pagination .pages) {
    display: flex;
    gap: 0.3rem;
  }

  :global(.pagination .pages button.active) {
    background: var(--brand-red);
    border-color: var(--brand-red);
    color: #fff;
    font-weight: 700;
  }

  /* ── Responsive ── */
  @media (max-width: 860px) {
    :global(.filter-row select),
    :global(.filter-row input) {
      flex: 1 1 110px;
    }

    :global(.car-thumb),
    :global(.car-thumb-placeholder) {
      width: 120px;
      height: 80px;
    }

    :global(.car-price-col) {
      min-width: 100px;
    }
  }

  @media (max-width: 560px) {
    :global(.car-row) {
      flex-wrap: wrap;
    }

    :global(.car-price-col) {
      width: 100%;
      text-align: left;
      min-width: 0;
    }

    :global(.filter-row) {
      flex-direction: column;
      align-items: stretch;
    }

    :global(.filter-actions) {
      margin-left: 0;
    }
  }
</style>
