---
import Layout from "../../layouts/Layout.astro";
import { getFaqPageContent } from "../../lib/wordpress";

interface FaqItem {
  question: string;
  answer: string;
}

const leftColumn: FaqItem[] = [
  {
    question: "Do you offer any sort of warranty?",
    answer:
      "Yes, we offer warranty options through our reliable third-party partners. Various coverage plans are available depending on your needs and the vehicle — ask us for details.",
  },
  {
    question: "Do you offer financing?",
    answer:
      "Yes! We can help you get approved for financing through our trusted network of financing partners across Canada. Whether you have good credit, no credit, or are rebuilding, we'll do our best to find an option that suits your needs.",
  },
  {
    question:
      "Can you help me find a specific car that's not in your inventory?",
    answer:
      "Absolutely. Just let us know what you're looking for, and we'll source the vehicle for you at the most competitive price through our trusted supplier and auction network.",
  },
  {
    question: "Do you offer car delivery?",
    answer:
      "Yes, we offer delivery services anywhere in Canada for an additional fee based on your location. Contact us for a custom quote.",
  },
  {
    question: "Do you export vehicles internationally?",
    answer:
      "Yes! We specialize in exporting vehicles worldwide. Whether you're located in the Middle East, Europe, or Asia, we can arrange reliable and efficient shipping to your destination.",
  },
  {
    question: "Where do you source your vehicles from?",
    answer:
      "We source high-quality vehicles from both Canada and the United States. This allows us to offer a wide selection of makes and models to meet your preferences and budget.",
  },
];

const rightColumn: FaqItem[] = [
  {
    question: "Are your vehicles safety certified?",
    answer:
      "Some of our vehicles are sold certified, while others can be certified for an additional fee. Certification includes a full inspection to ensure the vehicle meets Ontario safety standards. Buyers are also welcome to certify the vehicle with their own trusted mechanic.",
  },
  {
    question: "Do you take trade-ins?",
    answer:
      "Yes, we accept trade-ins. Bring your vehicle for an on-the-spot appraisal or contact us with the details (year, make, model, mileage, condition) and we'll provide an estimate.",
  },
  {
    question: "What documents do I need to bring when buying a car?",
    answer:
      "You'll need a valid driver's license and proof of insurance. If financing, additional documents like recent pay stubs, proof of address, or credit info may be required.",
  },
  {
    question: "Do you sell to customers outside Ontario?",
    answer:
      "Yes, we work with customers from across Canada. We can assist with out-of-province paperwork and offer delivery options as well.",
  },
  {
    question: "Are your prices competitive for export buyers?",
    answer:
      "Absolutely. We offer competitive pricing tailored for export clients through a network of shippers, and we can assist with documentation, shipping logistics, and compliance to ensure a smooth transaction from purchase\u00a0to\u00a0delivery.",
  },
];

type FetchState = "ok" | "not-found" | "error";
const MIN_FAQ_ITEMS_FOR_CMS = 8;

let fetchState: FetchState = "ok";
let cmsFaqItems: FaqItem[] = [];

try {
  const faq = await getFaqPageContent();
  // Use CMS items only when parsing returned a complete FAQ set.
  if (faq.items.length >= MIN_FAQ_ITEMS_FOR_CMS) {
    cmsFaqItems = faq.items;
  } else if (!faq.page) {
    fetchState = "not-found";
  }
} catch (error) {
  fetchState = "error";
  console.error("[faq] Failed to load FAQ content from WordPress", error);
}

const fallbackFaqItems = [...leftColumn, ...rightColumn];
const effectiveFaqItems =
  cmsFaqItems.length > 0 ? cmsFaqItems : fallbackFaqItems;
const midpoint = Math.ceil(effectiveFaqItems.length / 2);
const renderLeftColumn = effectiveFaqItems.slice(0, midpoint);
const renderRightColumn = effectiveFaqItems.slice(midpoint);
---

<Layout
  title="FAQ - AlfursanAuto.ca"
  description="FAQ about buying, financing, delivery, certification, and export services at Alfursan Auto."
  transparentHeader={true}
>
  <main class="container">
    {
      fetchState !== "ok" && (
        <p class="cms-status" role="status">
          {fetchState === "error"
            ? "Live FAQ content could not be loaded right now. Showing fallback content."
            : "Live FAQ content is not available. Showing fallback content."}
        </p>
      )
    }

    <section class="faq-shell">
      <section class="heading">
        <h2>Frequently Asked Questions</h2>
      </section>

      <div class="faq-grid">
        <div class="faq-column">
          {
            renderLeftColumn.map((item, index) => (
              <details class="faq-item" open={index === 0}>
                <summary class="faq-question">
                  <span>{item.question}</span>
                </summary>
                <div class="faq-answer">
                  <p>{item.answer}</p>
                </div>
              </details>
            ))
          }
        </div>

        <div class="faq-column">
          {
            renderRightColumn.map((item, index) => (
              <details class="faq-item" open={index === 0}>
                <summary class="faq-question">
                  <span>{item.question}</span>
                </summary>
                <div class="faq-answer">
                  <p>{item.answer}</p>
                </div>
              </details>
            ))
          }
        </div>
      </div>

      <div class="cta-row">
        <a href="/about-us/" class="btn">Learn more</a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .container {
    position: relative;
    max-width: 1466px;
    margin: 0 auto;
    padding: calc(2rem + 84px) 30px 4rem;
  }

  .container::before {
    content: "";
    position: absolute;
    top: 0;
    left: 50%;
    width: 100vw;
    height: 110px;
    transform: translateX(-50%);
    background: #040404;
    z-index: -1;
  }

  .faq-shell {
    background: #d4d8e2;
    border-radius: 24px;
    padding: clamp(1.2rem, 2vw, 1.8rem);
  }

  .cms-status {
    margin: 0 0 1rem;
    padding: 0.75rem 0.9rem;
    border-radius: 10px;
    border: 1px solid #f2d6a1;
    background: #fff4dd;
    color: #7a4d00;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .heading {
    margin-bottom: clamp(1rem, 1.8vw, 1.9rem);
  }

  h2 {
    margin: 0;
    font-size: clamp(2.4rem, 5vw, 4.6rem);
    line-height: 1.08;
    font-weight: 800;
    text-align: center;
    color: #1f2434;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
  }

  @media (max-width: 768px) {
    .faq-grid {
      grid-template-columns: 1fr;
    }
  }

  .faq-column {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .faq-item {
    background: #e5e5e8;
    border: 1px solid #c5ccda;
    border-radius: 20px;
    overflow: hidden;
    transition: border-color 0.2s ease;
  }

  .faq-item[open] {
    border-color: #cd463a;
  }

  .faq-question {
    list-style: none;
    padding: clamp(1rem, 1.2vw, 1.35rem) clamp(1rem, 1.4vw, 1.4rem);
    font-weight: 700;
    font-size: clamp(1.05rem, 1.35vw, 1.15rem);
    color: #222838;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    text-align: left;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question span:first-child {
    display: inline-block;
  }

  .faq-question::after {
    content: "⌄";
    font-size: 1.6rem;
    font-weight: 400;
    line-height: 1;
    color: #131313;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .faq-item[open] .faq-question::after {
    transform: rotate(180deg);
  }

  .faq-answer {
    border-top: 1px solid #cd463a;
  }

  .faq-answer p {
    margin: 0;
    padding: 0 clamp(1rem, 1.3vw, 1.4rem) clamp(1.1rem, 1.4vw, 1.35rem);
    color: #60656f;
    font-size: clamp(1rem, 1.18vw, 1.04rem);
    line-height: 1.65;
  }

  .cta-row {
    text-align: center;
    margin-top: 2.3rem;
  }

  .btn {
    display: inline-block;
    text-decoration: none;
    background: #c92214;
    color: #fff;
    border-radius: 12px;
    padding: 0.72rem 1.95rem;
    font-weight: 700;
    font-size: 1rem;
  }

  @media (max-width: 900px) {
    .faq-shell {
      border-radius: 20px;
    }

    h2 {
      max-width: 10ch;
      margin: 0 auto;
    }
  }
</style>
