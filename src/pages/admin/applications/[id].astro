---
export const prerender = false;

import AdminLayout from "../../../layouts/AdminLayout.astro";
import { getAdminClient } from "../../../lib/supabase-admin";
import { can } from "../../../lib/permissions";
import { formatStatusLabel } from "../../../lib/status-labels";
import { createHash, randomUUID } from "node:crypto";
import { Resend } from "resend";

const { adminEmail, adminRole } = Astro.locals;
const { id } = Astro.params;

if (!id) return Astro.redirect("/admin/applications/");

const supabase = getAdminClient();

// ── Handle POST actions ───────────────────────────────────────────────────────
if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("action");
  const ip = Astro.request.headers.get("x-forwarded-for")?.split(",")[0]?.trim() ?? "unknown";
  const ipHash = createHash("sha256").update(ip).digest("hex");

  if (action === "status_change" && can(adminRole!, "financing:write")) {
    const newStatus = form.get("status") as string;
    const valid = ["new", "reviewing", "approved", "declined", "document_incomplete", "documents_submitted"];
    if (valid.includes(newStatus)) {
      const updatePayload: Record<string, unknown> = { status: newStatus };

      if (newStatus === "document_incomplete") {
        const { data: current } = await supabase
          .from("applications")
          .select("email, full_name, phase2_token")
          .eq("id", id)
          .single();

        const token = current?.phase2_token ?? randomUUID();
        updatePayload.phase2_token = token;
        updatePayload.phase2_token_expires_at = new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toISOString();

        const siteUrl = import.meta.env.SITE_URL ?? "https://alfursanauto.ca";
        const phase2Link = `${siteUrl}/apply/phase2?token=${token}`;
        const resendKey   = import.meta.env.RESEND_API_KEY;
        const fromAddress = import.meta.env.RESEND_FROM_ADDRESS;

        if (resendKey && fromAddress && current?.email) {
          try {
            const resend = new Resend(resendKey);
            await resend.emails.send({
              from: fromAddress,
              to: current.email,
              subject: "Action Required — Complete Your Financing Application",
              text: [
                `Hi ${current.full_name ?? "Applicant"},`,
                "",
                "Thank you for applying with Alfursan Auto. To continue processing your financing application, we need a few additional documents from you.",
                "",
                "Please click the link below to upload your documents (valid for 30 days):",
                "",
                phase2Link,
                "",
                "You will need to provide:",
                "  • A void cheque",
                "  • Proof of insurance",
                "  • Your most recent payslip",
                "  • Two personal references",
                "",
                "If you have any questions, reply to this email or call us directly.",
                "",
                "— Alfursan Auto",
              ].join("\n"),
            });
          } catch (emailErr) {
            console.error("[admin] Phase 2 email error (non-fatal):", emailErr);
          }
        }

        await supabase.from("application_audit").insert({
          application_id: id,
          application_ref: id,
          action: "phase2_requested",
          admin_email: adminEmail,
          ip_hash: ipHash,
        });
      }

      const { error: updateErr } = await supabase.from("applications").update(updatePayload).eq("id", id);
      if (updateErr) {
        console.error("[admin] Status update error:", updateErr);
        return Astro.redirect(`/admin/applications/${id}/?error=Failed to update status`);
      }

      await supabase.from("application_audit").insert({
        application_id: id,
        application_ref: id,
        action: "status_changed",
        admin_email: adminEmail,
        ip_hash: ipHash,
      });
    }
  }

  if (action === "delete" && can(adminRole!, "financing:delete")) {
    const { data: toDelete } = await supabase
      .from("applications")
      .select("license_front_path, license_back_path, void_cheque_path, proof_insurance_path, payslip_path")
      .eq("id", id)
      .single();

    await supabase.from("application_audit").insert({
      application_id: id,
      application_ref: id,
      action: "deleted",
      admin_email: adminEmail,
      ip_hash: ipHash,
    });
    await supabase.from("applications").delete().eq("id", id);

    const paths = [
      toDelete?.license_front_path,
      toDelete?.license_back_path,
      toDelete?.void_cheque_path,
      toDelete?.proof_insurance_path,
      toDelete?.payslip_path,
    ].filter(Boolean) as string[];
    if (paths.length > 0) {
      await supabase.storage.from("license-documents").remove(paths);
    }

    return Astro.redirect("/admin/applications/");
  }

  return Astro.redirect(`/admin/applications/${id}/`);
}

// ── Fetch application ─────────────────────────────────────────────────────────
const { data: app, error } = await supabase
  .from("applications")
  .select("*")
  .eq("id", id)
  .single();

if (error || !app) return Astro.redirect("/admin/applications/");

// ── Fetch audit log ───────────────────────────────────────────────────────────
const { data: auditRows } = await supabase
  .from("application_audit")
  .select("action, admin_email, created_at")
  .eq("application_ref", id)
  .order("created_at", { ascending: false });

// ── Generate signed URLs ──────────────────────────────────────────────────────
let licenseFrontUrl: string | null = null;
let licenseBackUrl: string | null = null;

const ip = Astro.request.headers.get("x-forwarded-for")?.split(",")[0]?.trim() ?? "unknown";
const ipHash = createHash("sha256").update(ip).digest("hex");

const shortId = (app.id as string).slice(0, 8).toUpperCase();
const filePrefix = `REF-${shortId}`;

function licenseFilename(storagePath: string, side: "front" | "back"): string {
  const ext = storagePath.match(/\.[^.]+$/)?.[0] ?? ".jpg";
  return `${filePrefix}_${side}${ext}`;
}

function docFilename(storagePath: string, label: string): string {
  const ext = storagePath.match(/\.[^.]+$/)?.[0] ?? ".pdf";
  return `${filePrefix}_${label}${ext}`;
}

if (app.license_front_path && can(adminRole!, "financing:read")) {
  const { data } = await supabase.storage
    .from("license-documents")
    .createSignedUrl(app.license_front_path, 300, { download: licenseFilename(app.license_front_path, "front") });
  if (data) {
    licenseFrontUrl = data.signedUrl;
    supabase.from("application_audit").insert({
      application_id: id, application_ref: id,
      action: "viewed_license", admin_email: adminEmail, ip_hash: ipHash,
    });
  }
}

if (app.license_back_path && can(adminRole!, "financing:read")) {
  const { data } = await supabase.storage
    .from("license-documents")
    .createSignedUrl(app.license_back_path, 300, { download: licenseFilename(app.license_back_path, "back") });
  if (data) licenseBackUrl = data.signedUrl;
}

let voidChequeUrl:     string | null = null;
let proofInsuranceUrl: string | null = null;
let payslipUrl:        string | null = null;

if (can(adminRole!, "financing:read")) {
  if (app.void_cheque_path) {
    const { data } = await supabase.storage.from("license-documents")
      .createSignedUrl(app.void_cheque_path, 300, { download: docFilename(app.void_cheque_path, "void-cheque") });
    if (data) voidChequeUrl = data.signedUrl;
  }
  if (app.proof_insurance_path) {
    const { data } = await supabase.storage.from("license-documents")
      .createSignedUrl(app.proof_insurance_path, 300, { download: docFilename(app.proof_insurance_path, "proof-insurance") });
    if (data) proofInsuranceUrl = data.signedUrl;
  }
  if (app.payslip_path) {
    const { data } = await supabase.storage.from("license-documents")
      .createSignedUrl(app.payslip_path, 300, { download: docFilename(app.payslip_path, "payslip") });
    if (data) payslipUrl = data.signedUrl;
  }
}

function fmt(iso: string | null) {
  if (!iso) return "—";
  return new Date(iso).toLocaleDateString("en-CA", { year: "numeric", month: "short", day: "numeric" });
}

function money(v: number | null) {
  if (v == null) return "—";
  return `$${Number(v).toLocaleString("en-CA")}`;
}

const statusColor: Record<string, string> = {
  new:                  "#3b82f6",
  reviewing:            "#f59e0b",
  approved:             "#1a7f4b",
  declined:             "#B92111",
  document_incomplete:  "#7c3aed",
  documents_submitted:  "#0891b2",
};

const STATUSES = ["new", "reviewing", "document_incomplete", "documents_submitted", "approved", "declined"];

const heroAccent = statusColor[app.status as string] ?? "#99a1b2";
const hasDocuments = app.license_front_path || app.license_back_path
  || app.void_cheque_path || app.proof_insurance_path || app.payslip_path
  || (app.references && Array.isArray(app.references) && (app.references as any[]).length > 0);
const amountFinanced = app.vehicle_price != null && app.down_payment != null
  ? money(app.vehicle_price - app.down_payment) : null;
---

<AdminLayout title={`Application — ${app.full_name}`} activeNav="applications">

  {Astro.url.searchParams.get("error") && (
    <div class="alert-error">{Astro.url.searchParams.get("error")}</div>
  )}

  <!-- Breadcrumb -->
  <nav class="breadcrumb">
    <a href="/admin/applications/">Applications</a>
    <span class="breadcrumb__sep">›</span>
    <span>{app.full_name}</span>
  </nav>

  <!-- Hero ─────────────────────────────────────────────────────────────────── -->
  <div class="hero" style={`--accent: ${heroAccent}`}>
    <div class="hero__inner">
      <div class="hero__left">
        <div class="hero__name-row">
          <h1 class="hero__name">{app.full_name}</h1>
          <span class="hero__status-badge" style={`background:${heroAccent}1a; color:${heroAccent}; border-color:${heroAccent}44`}>
            <span class="hero__status-dot" style={`background:${heroAccent}`}></span>
            {formatStatusLabel(app.status)}
          </span>
        </div>
        <p class="hero__sub">
          <span class="hero__ref">REF-{shortId}</span>
          <span class="hero__bullet">·</span>
          Submitted {fmt(app.created_at)}
          {app.email && (
            <>
              <span class="hero__bullet">·</span>
              <a href={`mailto:${app.email}`} class="hero__email">{app.email}</a>
            </>
          )}
        </p>
      </div>
      {app.phone && (
        <a href={`tel:${app.phone}`} class="hero__phone-btn">{app.phone}</a>
      )}
    </div>

    <div class="hero__stats">
      <div class="hero__stat">
        <span class="hero__stat-label">Vehicle</span>
        <span class="hero__stat-value">
          {[app.vehicle_year, app.vehicle_make, app.vehicle_model].filter(Boolean).join(" ") || "—"}
        </span>
      </div>
      <div class="hero__stat-sep"></div>
      <div class="hero__stat">
        <span class="hero__stat-label">Price</span>
        <span class="hero__stat-value">{money(app.vehicle_price)}</span>
      </div>
      <div class="hero__stat-sep"></div>
      <div class="hero__stat">
        <span class="hero__stat-label">Down Payment</span>
        <span class="hero__stat-value">{money(app.down_payment)}</span>
      </div>
      {amountFinanced && (
        <>
          <div class="hero__stat-sep"></div>
          <div class="hero__stat">
            <span class="hero__stat-label">Amount Financed</span>
            <span class="hero__stat-value hero__stat-value--accent">{amountFinanced}</span>
          </div>
        </>
      )}
      <div class="hero__stat-sep"></div>
      <div class="hero__stat">
        <span class="hero__stat-label">Annual Income</span>
        <span class="hero__stat-value">{money(app.annual_income)}</span>
      </div>
      <div class="hero__stat-sep"></div>
      <div class="hero__stat">
        <span class="hero__stat-label">Loan Term</span>
        <span class="hero__stat-value">{app.loan_term_months ? `${app.loan_term_months} months` : "—"}</span>
      </div>
    </div>
  </div>

  <!-- Page body ────────────────────────────────────────────────────────────── -->
  <div class="page-body">

    <!-- Left: tabbed content ─────────────────────────────────────────── -->
    <div class="content-col">
      <div class="tabs" role="tablist" aria-label="Application details">
        <button class="tab tab--active" data-tab="personal"   role="tab" id="tab-btn-personal"   aria-selected="true"  aria-controls="tab-personal">Personal</button>
        <button class="tab"             data-tab="employment"  role="tab" id="tab-btn-employment" aria-selected="false" aria-controls="tab-employment">Employment</button>
        <button class="tab"             data-tab="vehicle"     role="tab" id="tab-btn-vehicle"    aria-selected="false" aria-controls="tab-vehicle">Vehicle & Loan</button>
        <button class="tab"             data-tab="documents"   role="tab" id="tab-btn-documents"  aria-selected="false" aria-controls="tab-documents">
          Documents
          {hasDocuments && <span class="tab__dot"></span>}
        </button>
        <button class="tab"             data-tab="activity"    role="tab" id="tab-btn-activity"   aria-selected="false" aria-controls="tab-activity">Activity</button>
      </div>

      <!-- ── Personal ── -->
      <div class="panel" id="tab-personal" role="tabpanel" aria-labelledby="tab-btn-personal">
        <div class="field-grid">
          <div class="field">
            <span class="field__label">Full Name</span>
            <span class="field__value">{app.full_name}</span>
          </div>
          <div class="field">
            <span class="field__label">Date of Birth</span>
            <span class="field__value">{app.dob ?? "—"}</span>
          </div>
          <div class="field">
            <span class="field__label">Phone</span>
            {app.phone
              ? <a class="field__value field__link" href={`tel:${app.phone}`}>{app.phone}</a>
              : <span class="field__value">—</span>
            }
          </div>
          <div class="field">
            <span class="field__label">Marital Status</span>
            <span class="field__value capitalize">{app.marital_status ?? "—"}</span>
          </div>
          <div class="field field--span2">
            <span class="field__label">Email</span>
            <a class="field__value field__link" href={`mailto:${app.email}`}>{app.email}</a>
          </div>
          <div class="field field--span2">
            <span class="field__label">Address</span>
            <span class="field__value">{[app.address, app.postal_code].filter(Boolean).join(", ") || "—"}</span>
          </div>
          <div class="field">
            <span class="field__label">Time at Address</span>
            <span class="field__value">{app.time_at_address ?? "—"}</span>
          </div>
        </div>

        {app.prev_addresses && Array.isArray(app.prev_addresses) && (app.prev_addresses as any[]).length > 0 && (
          <div class="sub-section">
            <h3 class="sub-section__title">Previous Addresses</h3>
            <div class="history-list">
              {(app.prev_addresses as any[]).map((p: any, i: number) => {
                const dateRange = p.untilMonth && p.untilYear
                  ? `${p.sinceMonth}/${p.sinceYear} – ${p.untilMonth}/${p.untilYear}`
                  : `from ${p.sinceMonth}/${p.sinceYear}`;
                return (
                  <div class="history-item">
                    <span class="history-item__num">{i + 1}</span>
                    <div>
                      <div class="history-item__main">{p.address}{p.postalCode ? `, ${p.postalCode}` : ""}</div>
                      <div class="history-item__meta">{dateRange}</div>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        )}
      </div>

      <!-- ── Employment ── -->
      <div class="panel panel--hidden" id="tab-employment" role="tabpanel" aria-labelledby="tab-btn-employment">
        <div class="field-grid">
          <div class="field">
            <span class="field__label">Employment Status</span>
            <span class="field__value capitalize">{app.employment_status ?? "—"}</span>
          </div>
          <div class="field">
            <span class="field__label">Job Title</span>
            <span class="field__value">{app.job_title ?? "—"}</span>
          </div>
          <div class="field field--span2">
            <span class="field__label">Employer</span>
            <span class="field__value">{app.employer ?? "—"}</span>
          </div>
          <div class="field field--span2">
            <span class="field__label">Employer Address</span>
            <span class="field__value">{app.employer_address ?? "—"}</span>
          </div>
          <div class="field">
            <span class="field__label">Employer Phone</span>
            {app.employer_phone
              ? <a class="field__value field__link" href={`tel:${app.employer_phone}`}>{app.employer_phone}</a>
              : <span class="field__value">—</span>
            }
          </div>
          <div class="field">
            <span class="field__label">Time at Employer</span>
            <span class="field__value">{app.time_at_employer ?? "—"}</span>
          </div>
          <div class="field field--highlight">
            <span class="field__label">Annual Income</span>
            <span class="field__value field__value--lg">{money(app.annual_income)}</span>
          </div>
        </div>

        {app.prev_employers && Array.isArray(app.prev_employers) && (app.prev_employers as any[]).length > 0 && (
          <div class="sub-section">
            <h3 class="sub-section__title">Previous Employers</h3>
            <div class="history-list">
              {(app.prev_employers as any[]).map((p: any, i: number) => {
                const dateRange = p.untilMonth && p.untilYear
                  ? `${p.sinceMonth}/${p.sinceYear} – ${p.untilMonth}/${p.untilYear}`
                  : `from ${p.sinceMonth}/${p.sinceYear}`;
                return (
                  <div class="history-item">
                    <span class="history-item__num">{i + 1}</span>
                    <div>
                      <div class="history-item__main">{p.employer}{p.address ? `, ${p.address}` : ""}{p.postalCode ? `, ${p.postalCode}` : ""}</div>
                      <div class="history-item__meta">{dateRange}</div>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        )}
      </div>

      <!-- ── Vehicle & Loan ── -->
      <div class="panel panel--hidden" id="tab-vehicle" role="tabpanel" aria-labelledby="tab-btn-vehicle">
        <div class="field-grid">
          <div class="field field--span2">
            <span class="field__label">Vehicle</span>
            <span class="field__value field__value--lg">
              {[app.vehicle_year, app.vehicle_make, app.vehicle_model].filter(Boolean).join(" ") || "—"}
            </span>
          </div>
          <div class="field field--span2">
            <span class="field__label">VIN</span>
            <span class="field__value" style="font-family:monospace;letter-spacing:0.04em">{app.vin ?? "—"}</span>
          </div>
          {app.listing_slug && (
            <div class="field field--span2">
              <span class="field__label">Listing</span>
              <a class="field__value field__link" href={`/listing/${app.listing_slug}/`} target="_blank" rel="noopener">
                {app.listing_slug} ↗
              </a>
            </div>
          )}
        </div>

        <div class="loan-grid">
          <div class="loan-stat">
            <span class="loan-stat__label">Vehicle Price</span>
            <span class="loan-stat__value">{money(app.vehicle_price)}</span>
          </div>
          <div class="loan-stat loan-stat--minus">
            <span class="loan-stat__label">Down Payment</span>
            <span class="loan-stat__value">{money(app.down_payment)}</span>
          </div>
          {amountFinanced && (
            <div class="loan-stat loan-stat--result">
              <span class="loan-stat__label">Amount Financed</span>
              <span class="loan-stat__value">{amountFinanced}</span>
            </div>
          )}
          <div class="loan-stat">
            <span class="loan-stat__label">Loan Term</span>
            <span class="loan-stat__value">{app.loan_term_months ? `${app.loan_term_months} months` : "—"}</span>
          </div>
        </div>
      </div>

      <!-- ── Documents ── -->
      <div class="panel panel--hidden" id="tab-documents" role="tabpanel" aria-labelledby="tab-btn-documents">
        {!hasDocuments && (
          <div class="empty-state">
            <div class="empty-state__icon">—</div>
            <p class="empty-state__text">No documents on file yet.</p>
          </div>
        )}

        {(app.license_front_path || app.license_back_path) && (
          <div class="doc-block">
            <h3 class="doc-block__title">Driver's License</h3>
            <div class="field-grid" style="margin-bottom:16px">
              <div class="field">
                <span class="field__label">Uploaded</span>
                <span class="field__value">{fmt(app.license_uploaded_at ?? null)}</span>
              </div>
            </div>
            {(licenseFrontUrl || licenseBackUrl) ? (
              <>
                <p class="doc-expire-note">Signed links expire in 5 minutes.</p>
                <div class="doc-btn-row">
                  {licenseFrontUrl && (
                    <a href={licenseFrontUrl} target="_blank" rel="noopener" class="doc-btn">License Front ↗</a>
                  )}
                  {licenseBackUrl && (
                    <a href={licenseBackUrl} target="_blank" rel="noopener" class="doc-btn">License Back ↗</a>
                  )}
                </div>
              </>
            ) : (
              <p class="doc-unavail">
                Files are on record, but a download link could not be generated right now. Reload the page to try again.
              </p>
            )}
          </div>
        )}

        {(app.void_cheque_path || app.proof_insurance_path || app.payslip_path || app.phase2_submitted_at) && (
          <div class="doc-block">
            <h3 class="doc-block__title">Phase 2 Documents</h3>
            <div class="field-grid" style="margin-bottom:16px">
              <div class="field">
                <span class="field__label">Submitted</span>
                <span class="field__value">{fmt(app.phase2_submitted_at ?? null)}</span>
              </div>
              <div class="field">
                <span class="field__label">DealerTrack Consent</span>
                <span class="field__value">{app.dealertrack_consent ? "Yes" : "No"}</span>
              </div>
            </div>
            {(voidChequeUrl || proofInsuranceUrl || payslipUrl) && (
              <>
                <p class="doc-expire-note">Signed links expire in 5 minutes.</p>
                <div class="doc-btn-row">
                  {voidChequeUrl && <a href={voidChequeUrl} target="_blank" rel="noopener" class="doc-btn">Void Cheque ↗</a>}
                  {proofInsuranceUrl && <a href={proofInsuranceUrl} target="_blank" rel="noopener" class="doc-btn">Proof of Insurance ↗</a>}
                  {payslipUrl && <a href={payslipUrl} target="_blank" rel="noopener" class="doc-btn">Payslip ↗</a>}
                </div>
              </>
            )}
          </div>
        )}

        {app.references && Array.isArray(app.references) && (app.references as any[]).length > 0 && (
          <div class="doc-block">
            <h3 class="doc-block__title">References</h3>
            <div class="ref-grid">
              {(app.references as any[]).map((r: any, i: number) => (
                <div class="ref-card">
                  <div class="ref-card__num">{i + 1}</div>
                  <div class="ref-card__body">
                    <div class="ref-card__name">{r.name}</div>
                    <div class="ref-card__rel">{r.relationship}</div>
                    <a href={`tel:${r.phone}`} class="ref-card__phone">{r.phone}</a>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- ── Activity ── -->
      <div class="panel panel--hidden" id="tab-activity" role="tabpanel" aria-labelledby="tab-btn-activity">
        <div class="field-grid" style="margin-bottom:28px">
          <div class="field">
            <span class="field__label">Submitted</span>
            <span class="field__value">{fmt(app.created_at)}</span>
          </div>
          <div class="field">
            <span class="field__label">Consent Given</span>
            <span class="field__value">{fmt(app.consent_timestamp)}</span>
          </div>
          <div class="field">
            <span class="field__label">License Consent</span>
            <span class="field__value">{app.license_consent ? "Yes" : "No"}</span>
          </div>
          {app.phase2_token && (
            <>
              <div class="field">
                <span class="field__label">Phase 2 Token</span>
                <span class="field__value" style="font-family:monospace">{(app.phase2_token as string).slice(0, 8)}…</span>
              </div>
              <div class="field">
                <span class="field__label">Phase 2 Token Expires</span>
                <span class="field__value">{fmt(app.phase2_token_expires_at ?? null)}</span>
              </div>
            </>
          )}
        </div>

        <h3 class="sub-section__title" style="margin-bottom:16px">Audit Log</h3>
        {(auditRows ?? []).length === 0 ? (
          <p class="muted-text">No events recorded.</p>
        ) : (
          <div class="timeline">
            {(auditRows ?? []).map((row: { action: string; admin_email: string; created_at: string }) => (
              <div class="tl-item">
                <div class="tl-dot"></div>
                <div class="tl-content">
                  <span class="tl-action">{row.action.replace(/_/g, " ")}</span>
                  <span class="tl-meta">{row.admin_email} · {fmt(row.created_at)}</span>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>

    <!-- Right: action panel ──────────────────────────────────────────── -->
    <div class="action-col">

      {can(adminRole!, "financing:write") && (
        <div class="action-card">
          <h2 class="action-card__title">Update Status</h2>

          {app.status === "document_incomplete" && app.phase2_token && (
            <div class="phase2-banner">
              <div class="phase2-banner__label">Phase 2 link active</div>
              <div class="phase2-banner__token">
                Token: <code>{(app.phase2_token as string).slice(0, 8)}…</code>
              </div>
              {app.phase2_token_expires_at && (
                <div class="phase2-banner__exp">Expires {fmt(app.phase2_token_expires_at)}</div>
              )}
            </div>
          )}

          <form method="POST">
            <input type="hidden" name="action" value="status_change" />
            <div class="status-picker">
              {STATUSES.map((s) => (
                <label
                  class={`status-opt${s === app.status ? " status-opt--active" : ""}`}
                  style={s === app.status ? `border-color:${statusColor[s]}; background:${statusColor[s]}12` : ""}
                >
                  <input type="radio" name="status" value={s} checked={s === app.status} />
                  <span class="status-opt__dot" style={`background:${statusColor[s] ?? "#99a1b2"}`}></span>
                  <span class="status-opt__label">{formatStatusLabel(s)}</span>
                  {s === app.status && <span class="status-opt__tag">current</span>}
                </label>
              ))}
            </div>
            <button type="submit" class="btn-submit">
              {app.status === "document_incomplete" ? "Resend Phase 2 Email" : "Update Status"}
            </button>
          </form>
        </div>
      )}

      {can(adminRole!, "financing:delete") && (
        <div class="action-card action-card--danger">
          <h2 class="action-card__title action-card__title--danger">Danger Zone</h2>
          <p class="danger-note">Deleting this application is permanent. The audit log will be preserved.</p>
          <form method="POST" onsubmit="return confirm('Permanently delete this application? This cannot be undone.')">
            <input type="hidden" name="action" value="delete" />
            <button type="submit" class="btn-delete">Delete Application</button>
          </form>
        </div>
      )}
    </div>
  </div>
</AdminLayout>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>(".tab");
  const panels = document.querySelectorAll<HTMLElement>(".panel");

  tabs.forEach((tab, i) => {
    tab.addEventListener("click", () => {
      const target = tab.dataset.tab!;
      tabs.forEach((t) => {
        t.classList.toggle("tab--active", t === tab);
        t.setAttribute("aria-selected", String(t === tab));
      });
      panels.forEach((p) => p.classList.toggle("panel--hidden", p.id !== `tab-${target}`));
    });
    tab.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.key === "ArrowRight") (tabs[(i + 1) % tabs.length] as HTMLButtonElement).focus();
      if (e.key === "ArrowLeft")  (tabs[(i - 1 + tabs.length) % tabs.length] as HTMLButtonElement).focus();
    });
  });
</script>

