---
export const prerender = false;

import AdminLayout from "../../../layouts/AdminLayout.astro";
import { getAdminClient } from "../../../lib/supabase-admin";

const { adminRole } = Astro.locals;
const supabase = getAdminClient();

// Pagination & filter from URL params
const PAGE_SIZE = 20;
const pageParam = Number(Astro.url.searchParams.get("page") ?? "1");
const page = Math.max(1, isNaN(pageParam) ? 1 : pageParam);
const statusFilter = Astro.url.searchParams.get("status") ?? "";

const VALID_STATUSES = ["new", "reviewing", "approved", "declined"];
const activeStatus = VALID_STATUSES.includes(statusFilter) ? statusFilter : "";

let query = supabase
  .from("applications")
  .select(
    "id, full_name, email, phone, status, created_at, vehicle_year, vehicle_make, vehicle_model, vehicle_price, employment_status",
    { count: "exact" }
  )
  .order("created_at", { ascending: false })
  .range((page - 1) * PAGE_SIZE, page * PAGE_SIZE - 1);

if (activeStatus) query = query.eq("status", activeStatus);

const { data: apps, count, error } = await query;

const total = count ?? 0;
const totalPages = Math.ceil(total / PAGE_SIZE);

function fmt(iso: string) {
  return new Date(iso).toLocaleDateString("en-CA", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}

function pageUrl(p: number) {
  const u = new URL(Astro.url);
  u.searchParams.set("page", String(p));
  return u.pathname + u.search;
}

function filterUrl(status: string) {
  const u = new URL(Astro.url);
  if (status) u.searchParams.set("status", status);
  else u.searchParams.delete("status");
  u.searchParams.delete("page");
  return u.pathname + u.search;
}

const statusColor: Record<string, string> = {
  new: "#3b82f6",
  reviewing: "#f59e0b",
  approved: "#1a7f4b",
  declined: "#B92111",
};
---

<AdminLayout title="Applications" activeNav="applications">
  <div class="page-header">
    <div>
      <h1>Applications</h1>
      <p>{total} total{activeStatus ? ` · filtered: ${activeStatus}` : ""}</p>
    </div>
  </div>

  <!-- Status filter tabs -->
  <div class="filter-tabs">
    {
      [
        { label: "All", value: "" },
        { label: "New", value: "new" },
        { label: "Reviewing", value: "reviewing" },
        { label: "Approved", value: "approved" },
        { label: "Declined", value: "declined" },
      ].map((f) => (
        <a
          href={filterUrl(f.value)}
          class={`filter-tab${activeStatus === f.value ? " filter-tab--active" : ""}`}
          style={activeStatus === f.value && f.value ? `color:${statusColor[f.value]}; border-color:${statusColor[f.value]}` : ""}
        >
          {f.label}
        </a>
      ))
    }
  </div>

  <div class="table-wrap section">
    {error ? (
      <div class="empty">Error loading applications. Please refresh.</div>
    ) : (apps ?? []).length === 0 ? (
      <div class="empty">No applications found.</div>
    ) : (
      <table class="table">
        <thead>
          <tr>
            <th>Applicant</th>
            <th>Vehicle</th>
            <th>Employment</th>
            <th>Status</th>
            <th>Date</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {(apps ?? []).map((app) => (
            <tr>
              <td>
                <div class="name-cell">
                  <strong>{app.full_name}</strong>
                  <span>{app.email}</span>
                </div>
              </td>
              <td>
                {[app.vehicle_year, app.vehicle_make, app.vehicle_model]
                  .filter(Boolean)
                  .join(" ") || "—"}
                {app.vehicle_price
                  ? ` · $${Number(app.vehicle_price).toLocaleString()}`
                  : ""}
              </td>
              <td>{app.employment_status ?? "—"}</td>
              <td>
                <span
                  class="badge"
                  style={`background:${statusColor[app.status]}22; color:${statusColor[app.status]}`}
                >
                  {app.status}
                </span>
              </td>
              <td style="white-space:nowrap">{fmt(app.created_at)}</td>
              <td>
                <a href={`/admin/applications/${app.id}/`} class="row-link">
                  View →
                </a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>

  <!-- Pagination -->
  {totalPages > 1 && (
    <div class="pagination">
      {page > 1 && (
        <a href={pageUrl(page - 1)} class="page-btn">← Prev</a>
      )}
      <span class="page-info">Page {page} of {totalPages}</span>
      {page < totalPages && (
        <a href={pageUrl(page + 1)} class="page-btn">Next →</a>
      )}
    </div>
  )}
</AdminLayout>

<style>
  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 20px;
  }
  .page-header h1 { font-size: 24px; font-weight: 800; color: #1a1d23; }
  .page-header p { color: #99a1b2; font-size: 14px; margin-top: 4px; }

  .filter-tabs {
    display: flex;
    gap: 4px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .filter-tab {
    padding: 6px 14px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 500;
    color: #99a1b2;
    border: 1px solid transparent;
    transition: background 0.15s, color 0.15s;
    background: #fff;
    border-color: #e4e7ec;
  }
  .filter-tab:hover { background: #f0f2f5; }
  .filter-tab--active {
    border-color: #1a1d23;
    color: #1a1d23;
    font-weight: 600;
  }

  .section {
    background: #fff;
    border: 1px solid #e4e7ec;
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 20px;
  }
  .empty { padding: 24px 20px; color: #99a1b2; font-size: 14px; }
  .table-wrap { overflow-x: auto; }
  .table { width: 100%; border-collapse: collapse; font-size: 14px; }
  .table th {
    text-align: left;
    padding: 10px 16px;
    font-size: 11px;
    font-weight: 700;
    color: #99a1b2;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid #e4e7ec;
    white-space: nowrap;
  }
  .table td {
    padding: 12px 16px;
    border-bottom: 1px solid #f0f2f5;
    color: #1a1d23;
    vertical-align: middle;
  }
  .table tr:last-child td { border-bottom: none; }
  .table tr:hover td { background: #f7f9fd; }
  .name-cell strong { display: block; font-weight: 600; }
  .name-cell span { display: block; font-size: 12px; color: #99a1b2; margin-top: 1px; }
  .badge {
    display: inline-block;
    padding: 2px 9px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 600;
    text-transform: capitalize;
  }
  .row-link { color: #B92111; font-size: 13px; font-weight: 500; }

  .pagination {
    display: flex;
    align-items: center;
    gap: 12px;
    justify-content: center;
    padding: 8px 0;
  }
  .page-btn {
    padding: 7px 16px;
    border: 1px solid #e4e7ec;
    border-radius: 6px;
    background: #fff;
    font-size: 14px;
    color: #1a1d23;
    font-weight: 500;
    transition: background 0.15s;
  }
  .page-btn:hover { background: #f0f2f5; }
  .page-info { font-size: 14px; color: #99a1b2; }
</style>
