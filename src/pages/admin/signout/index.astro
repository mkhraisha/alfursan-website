---
/**
 * Sign-out page. Clears the session cookie then redirects to login.
 */
export const prerender = false;
const SUPABASE_URL = import.meta.env.SUPABASE_URL ?? "";
const SUPABASE_PUBLISHABLE_KEY = import.meta.env.SUPABASE_PUBLISHABLE_KEY ?? "";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Signing out…</title>
  </head>
  <body>
    <div id="supabase-config" data-url={SUPABASE_URL} data-key={SUPABASE_PUBLISHABLE_KEY} hidden></div>

    <script>
      import { createClient } from "@supabase/supabase-js";

      const config = document.getElementById("supabase-config") as HTMLElement;
      const supabase = createClient(config.dataset.url!, config.dataset.key!);

      await supabase.auth.signOut();
      document.cookie = "sb-access-token=; path=/; max-age=0; SameSite=Lax";
      window.location.replace("/admin/");
    </script>
  </body>
</html>
