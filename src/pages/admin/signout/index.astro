---
/**
 * Sign-out handler. Clears the HttpOnly session cookie server-side then
 * redirects to the login page.
 *
 * The cookie is HttpOnly so it cannot be cleared from JavaScript; only the
 * server can expire it via a Set-Cookie header.
 */
export const prerender = false;

return new Response(null, {
  status: 302,
  headers: {
    Location: "/admin/",
    "Set-Cookie": "sb-access-token=; HttpOnly; SameSite=Lax; Path=/; Max-Age=0",
  },
});
---
