---
/**
 * Sign-out page. Clears the session cookie then redirects to login.
 * This is a static page; JS handles the sign-out.
 */
const SUPABASE_URL = import.meta.env.SUPABASE_URL ?? "";
const SUPABASE_PUBLISHABLE_KEY = import.meta.env.SUPABASE_PUBLISHABLE_KEY ?? "";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Signing out…</title>
  </head>
  <body>
    <script define:vars={{ SUPABASE_URL, SUPABASE_PUBLISHABLE_KEY }}>
      import { createClient } from "https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/+esm";
      const supabase = createClient(SUPABASE_URL, SUPABASE_PUBLISHABLE_KEY);
      await supabase.auth.signOut();
      // Clear the access token cookie
      document.cookie = "sb-access-token=; path=/; max-age=0; SameSite=Lax";
      window.location.replace("/admin/");
    </script>
  </body>
</html>
