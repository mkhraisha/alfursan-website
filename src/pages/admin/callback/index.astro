---
/**
 * OAuth callback handler. Supabase redirects here after magic-link click.
 * Exchanges the URL fragment token for a session cookie, then redirects to dashboard.
 * This page is static (JS does all the work client-side).
 */
const SUPABASE_URL = import.meta.env.SUPABASE_URL ?? "";
const SUPABASE_PUBLISHABLE_KEY = import.meta.env.SUPABASE_PUBLISHABLE_KEY ?? "";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Signing in… — Alfursan Admin</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: 'Inter', sans-serif;
        background: #f0f2f5;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1a1d23;
      }
      .message {
        text-align: center;
        font-size: 16px;
        color: #99a1b2;
      }
      .message strong { display: block; font-size: 20px; color: #1a1d23; margin-bottom: 8px; }
    </style>
  </head>
  <body>
    <p class="message" id="msg"><strong>Verifying…</strong>Please wait while we sign you in.</p>

    <script define:vars={{ SUPABASE_URL, SUPABASE_PUBLISHABLE_KEY }}>
      import { createClient } from "https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/+esm";

      const supabase = createClient(SUPABASE_URL, SUPABASE_PUBLISHABLE_KEY);
      const msg = document.getElementById("msg");

      // Supabase puts the tokens in the URL hash after magic-link click.
      // getSession() will pick them up automatically.
      const { data, error } = await supabase.auth.getSession();

      if (error || !data?.session) {
        msg.innerHTML = '<strong style="color:#B92111">Sign-in failed.</strong><br><a href="/admin/" style="color:#B92111">Try again</a>';
      } else {
        // Persist the access token as a cookie so the Astro middleware can read it.
        const token = data.session.access_token;
        const maxAge = data.session.expires_in ?? 3600;
        document.cookie = `sb-access-token=${encodeURIComponent(token)}; path=/; max-age=${maxAge}; SameSite=Lax`;
        window.location.replace("/admin/dashboard/");
      }
    </script>
  </body>
</html>
