---
import SpeedInsights from "@vercel/speed-insights/astro";

/**
 * Shared layout for all /admin/* pages.
 * Requires Astro.locals.adminEmail and adminRole (set by middleware).
 */
import { can } from "../lib/permissions";

interface Props {
  title: string;
  activeNav?: "dashboard" | "applications" | "inventory" | "garage" | "users";
}

const { title, activeNav } = Astro.props;
const { adminEmail, adminRole } = Astro.locals;

const nav = [
  { id: "dashboard",    label: "Dashboard",       href: "/admin/dashboard/",    icon: "◈" },
  { id: "applications", label: "Applications",    href: "/admin/applications/", icon: "◻" },
  { id: "inventory",    label: "Inventory",       href: "/admin/inventory/",    icon: "◉" },
  { id: "garage",       label: "Garage Register", href: "/admin/garage/",       icon: "◧" },
  ...(can(adminRole, "dealer:users:manage")
    ? [{ id: "users", label: "Users", href: "/admin/users/", icon: "◑" }]
    : []),
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} — Alfursan Admin</title>
    <SpeedInsights />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: 'Inter', sans-serif;
        background: #f0f2f5;
        color: #1a1d23;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      a { color: inherit; text-decoration: none; }

      /* ── Top bar ──────────────────────────────────────────────────── */
      .topbar {
        background: #1a1d23;
        color: #e8eaf0;
        height: 52px;
        display: flex;
        align-items: center;
        padding: 0 20px;
        gap: 16px;
        flex-shrink: 0;
        position: sticky;
        top: 0;
        z-index: 100;
        border-bottom: 1px solid #2d3139;
      }
      .topbar__brand {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 14px;
        font-weight: 700;
        color: #fff;
        white-space: nowrap;
        flex-shrink: 0;
      }
      .topbar__logo { color: #b92111; font-size: 18px; }
      .topbar__divider {
        width: 1px;
        height: 20px;
        background: #2d3139;
        flex-shrink: 0;
      }
      .topbar__title {
        font-size: 13px;
        color: #6b7280;
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .topbar__user {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 12px;
        color: #99a1b2;
        flex-shrink: 0;
      }
      .topbar__email {
        color: #c8ccd6;
        max-width: 180px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .topbar__role {
        background: rgba(255,255,255,0.08);
        border-radius: 4px;
        padding: 2px 7px;
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: #6b7280;
      }
      .topbar__signout {
        color: #b92111;
        font-size: 12px;
        padding: 4px 8px;
        border-radius: 4px;
        transition: background 0.15s;
        cursor: pointer;
      }
      .topbar__signout:hover { background: rgba(185,33,17,0.15); }

      /* ── Body with sidebar ──────────────────────────────────────────── */
      .layout {
        display: flex;
        flex: 1;
        min-height: 0;
      }

      /* ── Sidebar ──────────────────────────────────────────────────── */
      .sidebar {
        width: 220px;
        flex-shrink: 0;
        background: #fff;
        border-right: 1px solid #e4e7ec;
        display: flex;
        flex-direction: column;
        padding: 16px 0;
        position: sticky;
        top: 52px;
        height: calc(100vh - 52px);
        overflow-y: auto;
      }
      .sidebar__section {
        padding: 4px 12px;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #99a1b2;
        margin-top: 8px;
        margin-bottom: 4px;
      }
      .sidebar__link {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 16px;
        font-size: 14px;
        color: #4b5563;
        transition: background 0.12s, color 0.12s;
        border-left: 3px solid transparent;
      }
      .sidebar__link:hover {
        background: #f8f9fb;
        color: #1a1d23;
      }
      .sidebar__link--active {
        background: #fef2f1;
        color: #b92111;
        border-left-color: #b92111;
        font-weight: 600;
      }
      .sidebar__icon { font-size: 15px; width: 20px; text-align: center; }

      /* ── Main content ─────────────────────────────────────────────── */
      .main {
        flex: 1;
        padding: 28px;
        min-width: 0;
        max-width: 1100px;
      }
    </style>
  </head>
  <body>
    <header class="topbar">
      <a href="/admin/dashboard/" class="topbar__brand">
        <span class="topbar__logo">⬟</span>
        Alfursan Admin
      </a>
      <div class="topbar__divider"></div>
      <span class="topbar__title">{title}</span>
      <div class="topbar__user">
        <span class="topbar__email">{adminEmail}</span>
        <span class="topbar__role">{adminRole}</span>
        <a href="/admin/signout/" class="topbar__signout">Sign out</a>
      </div>
    </header>

    <div class="layout">
      <aside class="sidebar">
        <span class="sidebar__section">Main</span>
        {nav.map((item) => (
          <a
            href={item.href}
            class={`sidebar__link${activeNav === item.id ? " sidebar__link--active" : ""}`}
          >
            <span class="sidebar__icon">{item.icon}</span>
            {item.label}
          </a>
        ))}
      </aside>

      <main class="main">
        <slot />
      </main>
    </div>
  </body>
</html>
