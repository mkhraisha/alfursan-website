---
import { rootCss } from "../lib/theme";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  schema?: Record<string, unknown>;
  transparentHeader?: boolean;
}

type NavLink = {
  label: string;
  href: string;
};

const SITE_URL = "https://alfursanauto.ca";
const DEFAULT_OG_IMAGE = `${SITE_URL}/wp-content/uploads/2025/06/al-fursan-logo-transparent.png`;

const {
  title = "Alfursan Auto",
  description = "Trusted used car dealership in the Greater Toronto Area. Browse inspected vehicles, wholesale deals, and international exports.",
  image,
  schema,
  transparentHeader = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, SITE_URL).href;
const ogImage = image ?? DEFAULT_OG_IMAGE;

const BASE = import.meta.env.BASE_URL;
const navLinks: NavLink[] = [
  { label: "Home", href: BASE },
  { label: "Search", href: `${BASE}search/` },
  { label: "About us", href: `${BASE}about-us/` },
  { label: "Contact", href: `${BASE}contact-us/` },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string): boolean => {
  if (href === BASE) {
    return currentPath === BASE || currentPath === BASE.slice(0, -1);
  }
  return currentPath.startsWith(href);
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" sizes="32x32" href={`${import.meta.env.BASE_URL}favicon-32x32.png`} />
    <link rel="icon" type="image/png" sizes="192x192" href={`${import.meta.env.BASE_URL}favicon.png`} />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}favicon.png`} />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Alfursan Auto" />
    <meta property="og:locale" content="en_CA" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css?family=Muli:300,300italic,400,400italic,500,500italic,600,600italic,700,700italic,800,800italic,900,900italic&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap"
      rel="stylesheet"
    />
    <Fragment set:html={`<style>:root{${rootCss()}}</style>`} />
    {
      schema && (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      )
    }
  </head>

  <body>
    <header
      class:list={["site-header", { "header-transparent": transparentHeader }]}
    >
      <div class="shell">
        <a href={import.meta.env.BASE_URL} class="brand" aria-label="Alfursan Auto Home">
          <img
            src="https://alfursanauto.ca/wp-content/uploads/2025/06/al-fursan-logo-transparent.png"
            alt="Alfursan Auto"
            loading="lazy"
          />
        </a>

        <nav class="desktop-nav" aria-label="Primary">
          {
            navLinks.map((link) => (
              <a
                href={link.href}
                class={isActive(link.href) ? "active" : undefined}
              >
                {link.label}
              </a>
            ))
          }
        </nav>

        <a href={`${import.meta.env.BASE_URL}contact-us/`} class="cta">+ Book a Demo</a>

        <details class="mobile-nav">
          <summary>Menu</summary>
          <nav class="mobile-panel" aria-label="Mobile Primary">
            {
              navLinks.map((link) => (
                <a
                  href={link.href}
                  class={isActive(link.href) ? "active" : undefined}
                >
                  {link.label}
                </a>
              ))
            }
            <a href={`${import.meta.env.BASE_URL}contact-us/`} class="cta">+ Book a Demo</a>
          </nav>
        </details>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="shell footer-grid">
        <div class="footer-col-brand">
          <a href={import.meta.env.BASE_URL} class="footer-logo">
            <img
              src="https://alfursanauto.ca/wp-content/uploads/2025/06/al-fursan-logo-transparent-reversed.png"
              alt="AlfursanAuto.ca"
              loading="lazy"
            />
          </a>
          <ul class="footer-links-grid">
            <li><a href={`${import.meta.env.BASE_URL}search/`}>Listings</a></li>
            <li><a href={`${import.meta.env.BASE_URL}faq/`}>FAQ</a></li>
            <li><a href={`${import.meta.env.BASE_URL}about-us/`}>About us</a></li>
            <li><a href={`${import.meta.env.BASE_URL}contact-us/`}>Contact</a></li>
          </ul>
        </div>

        <div class="footer-col-desc">
          <p class="footer-text">
            Alfursan Auto is a trusted used car dealership based in the Greater
            Toronto Area, specializing in retail sales, wholesale deals, and
            international vehicle exports. We're committed to offering quality
            vehicles, transparent service, and personalized support whether
            you're buying locally or shipping overseas. Driven by honesty and
            reliability, Alfursan Auto makes your car buying experience smooth,
            secure, and hassle-free.
          </p>
        </div>

        <div class="footer-col-contact">
          <a href="tel:+14168384007" class="footer-phone">
            <span class="footer-phone-prefix">+1</span> (416) 838-4007
          </a>
          <a href="mailto:sales@alfursanauto.ca" class="footer-email"
            >sales@alfursanauto.ca</a
          >
          <p class="footer-address">5866 Mayfield Rd, Caledon, ON L7C 0Z6</p>
        </div>
      </div>

      <div class="shell footer-bottom">
        <p>© 2025 Alfursan Auto. All rights reserved.</p>
        <div class="footer-social">
          <a
            href="https://www.facebook.com/people/Alfursan-Auto-Exports/61576687765706/"
            target="_blank"
            rel="noreferrer"
            class="social-icon"
            aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512" width="12" height="12"><path d="M80 299.3V512H196V299.3h86.5l18-97.8H196V166.9c0-51.7 20.3-71.5 72.7-71.5c16.3 0 29.4 .4 37 1.2V7.9C291.4 4 256.4 0 236.2 0C129.3 0 80 50.5 80 159.4v42.1H14v97.8H80z" fill="currentColor"/></svg>
          </a>
          <a
            href="https://www.instagram.com/alfursanauto/"
            target="_blank"
            rel="noreferrer"
            class="social-icon"
            aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" width="12" height="12"><path d="M224.1 141c-63.6 0-114.9 51.3-114.9 114.9s51.3 114.9 114.9 114.9S339 319.5 339 255.9 287.7 141 224.1 141zm0 189.6c-41.1 0-74.7-33.5-74.7-74.7s33.5-74.7 74.7-74.7 74.7 33.5 74.7 74.7-33.6 74.7-74.7 74.7zm146.4-194.3c0 14.9-12 26.8-26.8 26.8-14.9 0-26.8-12-26.8-26.8s12-26.8 26.8-26.8 26.8 12 26.8 26.8zm76.1 27.2c-1.7-35.9-9.9-67.7-36.2-93.9-26.2-26.2-58-34.4-93.9-36.2-37-2.1-147.9-2.1-184.9 0-35.8 1.7-67.6 9.9-93.9 36.1s-34.4 58-36.2 93.9c-2.1 37-2.1 147.9 0 184.9 1.7 35.9 9.9 67.7 36.2 93.9s58 34.4 93.9 36.2c37 2.1 147.9 2.1 184.9 0 35.9-1.7 67.7-9.9 93.9-36.2 26.2-26.2 34.4-58 36.2-93.9 2.1-37 2.1-147.8 0-184.8zM398.8 388c-7.8 19.6-22.9 34.7-42.6 42.6-29.5 11.7-99.5 9-132.1 9s-102.7 2.6-132.1-9c-19.6-7.8-34.7-22.9-42.6-42.6-11.7-29.5-9-99.5-9-132.1s-2.6-102.7 9-132.1c7.8-19.6 22.9-34.7 42.6-42.6 29.5-11.7 99.5-9 132.1-9s102.7-2.6 132.1 9c19.6 7.8 34.7 22.9 42.6 42.6 11.7 29.5 9 99.5 9 132.1s2.7 102.7-9 132.1z" fill="currentColor"/></svg>
          </a>
        </div>
      </div>
    </footer>

    <script>
      const header = document.querySelector(".site-header.header-transparent");
      if (header) {
        const update = () =>
          header.classList.toggle("scrolled", window.scrollY > 50);
        update();
        window.addEventListener("scroll", update, { passive: true });
      }
    </script>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(body) {
    margin: 0;
    font-family: Muli, Arial, Helvetica, sans-serif;
    color: var(--ink);
    background: var(--bg);
    font-size: 16px;
    line-height: 1.69;
    overflow-x: hidden;
    overflow-wrap: break-word;
  }

  :global(a) {
    color: inherit;
  }

  .site-header {
    background: var(--surface);
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    z-index: 10;
    transition:
      background 0.3s,
      border-color 0.3s,
      box-shadow 0.3s;
  }

  .site-header.header-transparent {
    position: fixed;
    width: 100%;
    background: transparent;
    border-bottom-color: transparent;
  }

  .site-header.header-transparent .desktop-nav a,
  .site-header.header-transparent .brand img {
    filter: brightness(0) invert(1);
  }

  .site-header.header-transparent .desktop-nav a {
    color: #fff;
  }

  .site-header.header-transparent .desktop-nav a.active {
    background: transparent;
    font-weight: 800;
  }

  .site-header.header-transparent .header-contact {
    color: rgba(255, 255, 255, 0.75) !important;
  }

  .site-header.header-transparent .header-contact:hover {
    color: #fff !important;
  }

  .site-header.header-transparent .desktop-nav .cta,
  .site-header.header-transparent .cta {
    filter: none;
    color: #fff;
    border-color: #fff;
    background: transparent;
  }

  .site-header.header-transparent.scrolled {
    background: var(--surface);
    border-bottom-color: var(--line);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  }

  .site-header.header-transparent.scrolled .desktop-nav a,
  .site-header.header-transparent.scrolled .brand img {
    filter: none;
  }

  .site-header.header-transparent.scrolled .desktop-nav a {
    color: var(--ink);
  }

  .site-header.header-transparent.scrolled .desktop-nav a.active {
    color: #fff;
  }

  .site-header.header-transparent.scrolled .header-contact {
    color: var(--muted) !important;
  }

  .site-header.header-transparent.scrolled .header-contact:hover {
    color: var(--brand-red) !important;
  }

  .site-header.header-transparent.scrolled .desktop-nav .cta,
  .site-header.header-transparent.scrolled .cta {
    color: var(--ink);
    border-color: var(--ink);
    background: transparent;
  }

  .shell {
    margin: 0 auto;
    max-width: 1466px;
    padding: 0.9rem 30px;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .brand {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }

  .brand img {
    height: 42px;
    width: auto;
  }

  .desktop-nav {
    display: flex;
    gap: 0.9rem;
    align-items: center;
  }

  .cta {
    margin-left: auto;
  }

  .desktop-nav a,
  .mobile-panel a {
    color: var(--ink);
    text-decoration: none;
    font-weight: 600;
    letter-spacing: 0.02em;
    font-size: 0.88rem;
    border-radius: 999px;
    padding: 0.4rem 0.68rem;
  }

  .desktop-nav a:hover,
  .mobile-panel a:hover {
    background: var(--bg);
  }

  .desktop-nav a.active,
  .mobile-panel a.active {
    background: var(--brand-red);
    color: #fff;
  }

  .desktop-nav .cta,
  .mobile-panel .cta,
  .cta {
    background: transparent;
    color: var(--ink);
    border: 1.5px solid var(--ink);
    font-weight: 700;
    padding: 0.5rem 1.2rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-size: 0.78rem;
    text-decoration: none;
    border-radius: 999px;
    white-space: nowrap;
  }

  .desktop-nav .cta:hover,
  .mobile-panel .cta:hover,
  .cta:hover {
    background: var(--ink);
    color: #fff;
  }

  .header-contact {
    text-transform: none;
    font-weight: 600;
    font-size: 0.8rem;
    color: var(--muted) !important;
    letter-spacing: normal;
  }

  .header-contact:hover {
    color: var(--brand-red) !important;
    background: transparent;
  }

  .mobile-nav {
    display: none;
    position: relative;
  }

  .mobile-nav summary {
    list-style: none;
    cursor: pointer;
    font-weight: 700;
    border: 1px solid var(--menu-border);
    padding: 0.45rem 0.62rem;
    border-radius: 8px;
    background: #fff;
  }

  .mobile-nav summary::-webkit-details-marker {
    display: none;
  }

  .mobile-panel {
    position: absolute;
    right: 0;
    top: calc(100% + 0.5rem);
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 0.45rem;
    display: grid;
    gap: 0.25rem;
    min-width: 200px;
    box-shadow: 0 14px 32px rgba(16, 24, 40, 0.12);
  }

  .site-footer {
    margin-top: 2.5rem;
    background: var(--footer-bg);
    color: var(--surface);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr 1.8fr 1fr;
    gap: 2rem;
    padding-top: 3rem;
    padding-bottom: 2.5rem;
    align-items: start;
  }

  .footer-logo {
    display: inline-block;
    margin-bottom: 1.2rem;
  }

  .footer-logo img {
    height: 36px;
    width: auto;
  }

  .footer-links-grid {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem 1.5rem;
  }

  .footer-links-grid a {
    font-size: 0.92rem;
    color: var(--surface);
    text-decoration: none;
    position: relative;
    padding-left: 0.9rem;
  }

  .footer-links-grid a::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--brand-red);
  }

  .footer-text {
    margin: 0;
    line-height: 1.7;
    color: var(--surface);
    font-size: 0.92rem;
  }

  .footer-col-contact {
    text-align: right;
  }

  .footer-phone {
    display: block;
    text-decoration: none;
    color: var(--surface);
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 0.3rem;
  }

  .footer-phone-prefix {
    color: var(--brand-red);
    font-weight: 800;
  }

  .footer-email {
    display: block;
    text-decoration: none;
    color: var(--surface);
    font-size: 0.92rem;
  }

  .footer-address {
    margin: 0.4rem 0 0;
    font-size: 0.85rem;
    color: var(--surface);
    opacity: 0.75;
  }

  .site-footer a {
    text-decoration: none;
    color: var(--surface);
  }

  .footer-bottom {
    border-top: 1px solid var(--footer-divider);
    padding-top: 0.8rem;
    padding-bottom: 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .footer-bottom p {
    margin: 0;
    color: var(--surface);
    font-size: 0.85rem;
  }

  .footer-social {
    display: flex;
    gap: 0.5rem;
  }

  .social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1px solid var(--footer-divider);
    color: var(--surface);
    font-size: 0.75rem;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.2s;
  }

  .social-icon:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  @media (max-width: 640px) {
    .shell {
      gap: 0.6rem;
    }

    .desktop-nav {
      display: none;
    }

    .mobile-nav {
      display: block;
    }

    .topbar-shell {
      justify-content: flex-start;
    }
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
